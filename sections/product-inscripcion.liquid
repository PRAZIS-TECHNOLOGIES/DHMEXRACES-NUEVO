<script>
  function changeMainImage(button) {
    const newImage = button.getAttribute('data-image');
    document.getElementById('mainProductImage').src = newImage;
    document.querySelectorAll('.inscripcion__thumb').forEach(thumb => thumb.classList.remove('is-active'));
    button.classList.add('is-active');
  }

  function selectCategoria(button) {
    if (button.disabled) return;

    // Quitar seleccion anterior
    document.querySelectorAll('.inscripcion__cat-btn').forEach(row => row.classList.remove('is-selected'));

    // Seleccionar nueva
    button.classList.add('is-selected');

    // Actualizar hidden input
    document.getElementById('selectedVariantId').value = button.getAttribute('data-variant-id');

    // Actualizar resumen - usar data-variant-title para evitar el badge
    const nombre = button.getAttribute('data-variant-title');
    const precio = button.getAttribute('data-price');
    document.getElementById('resumenCategoria').textContent = nombre;
    document.getElementById('resumenPrecio').textContent = precio;

    // No scroll - el usuario sigue seleccionando
  }

  function increaseQty() {
    const input = document.getElementById('quantity');
    input.value = parseInt(input.value) + 1;
  }

  function decreaseQty() {
    const input = document.getElementById('quantity');
    if (parseInt(input.value) > 1) input.value = parseInt(input.value) - 1;
  }

  function mostrarToast(cantidad, categoria) {
    const toast = document.getElementById('toastNotification');
    const subtitle = document.getElementById('toastSubtitle');
    subtitle.textContent = cantidad + 'x ' + categoria;
    toast.classList.add('is-visible');

    // Auto cerrar despues de 4 segundos
    setTimeout(() => {
      cerrarToast();
    }, 4000);
  }

  function cerrarToast() {
    const toast = document.getElementById('toastNotification');
    toast.classList.remove('is-visible');
  }

  async function actualizarBadgesCarrito() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();

      // Resetear todos los badges
      document.querySelectorAll('[data-cart-badge]').forEach(badge => {
        badge.style.display = 'none';
        badge.textContent = '0';
      });

      // Filtrar items de este producto
      const productItems = cart.items.filter(item => {
        const badge = document.querySelector(`[data-cart-badge="${item.variant_id}"]`);
        return badge !== null;
      });

      // Actualizar badges con items del carrito
      productItems.forEach(item => {
        const badge = document.querySelector(`[data-cart-badge="${item.variant_id}"]`);
        if (badge) {
          badge.textContent = item.quantity;
          badge.style.display = 'inline-flex';
        }
      });

      // Actualizar resumen del carrito (siempre visible)
      const carritoItems = document.getElementById('carritoItems');
      const carritoEmpty = document.getElementById('carritoEmpty');
      const carritoLink = document.getElementById('carritoLink');

      if (productItems.length > 0) {
        // Crear lista de items
        const itemsHTML = productItems.map(item => {
          return `<span class="inscripcion__cart-item">${item.quantity}x ${item.variant_title}</span>`;
        }).join('');

        carritoItems.innerHTML = itemsHTML;
        if (carritoLink) carritoLink.style.display = 'block';
      } else {
        // Mostrar mensaje de vacío
        carritoItems.innerHTML = '<span class="inscripcion__cart-empty">Aún no has agregado inscripciones</span>';
        if (carritoLink) carritoLink.style.display = 'none';
      }

      // Actualizar contador global del carrito
      const cartCount = document.querySelector('.cart-count, .cart-item-count, [data-cart-count]');
      if (cartCount) {
        cartCount.textContent = cart.item_count;
      }
    } catch (error) {
      console.error('Error actualizando badges:', error);
    }
  }

  // Store jersey availability globally
  let jerseyData = null;

  async function agregarAlCarrito() {
    const variantId = document.getElementById('selectedVariantId').value;
    const quantity = document.getElementById('quantity').value;
    const btn = document.querySelector('.inscripcion__btn--cart');
    const selectedRow = document.querySelector('.inscripcion__cat-btn.is-selected');
    const categoriaName = selectedRow ? selectedRow.getAttribute('data-variant-title') : 'Inscripción';

    // Deshabilitar boton
    btn.disabled = true;
    btn.innerHTML = '<span class="loading-spinner"></span> Agregando...';

    try {
      // Add inscription to cart
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variantId,
          quantity: parseInt(quantity)
        })
      });

      if (response.ok) {
        // Check if jerseys are available and handle them properly
        if (jerseyData && jerseyData.disponible && jerseyData.jerseyVariantId) {
          try {
            // IMPORTANT: Check if a promo jersey already exists in the cart
            const cartResponse = await fetch('/cart.js');
            const cart = await cartResponse.json();

            // Count total inscriptions in cart (including the one we just added)
            const totalInscriptions = cart.items
              .filter(item => {
                const title = (item.product_title || '').toLowerCase();
                return title.includes('inscripcion') || title.includes('inscripción');
              })
              .reduce((total, item) => total + item.quantity, 0);

            // Fetch available jerseys from inventory API to cap quantity
            let jerseyQty = totalInscriptions;
            try {
              const invResponse = await fetch('https://dhmexraces-webhooks.vercel.app/api/inventory');
              const invData = await invResponse.json();
              const sede = (jerseyData.sede || 'guanajuato').toLowerCase();
              const disponibles = invData.sedes?.[sede]?.playeras?.disponibles ?? 50;
              jerseyQty = Math.min(totalInscriptions, disponibles);
            } catch (invErr) {
              console.error('Error fetching inventory, using totalInscriptions:', invErr);
            }

            // Find existing promo jersey
            const existingPromoJersey = cart.items.find(item => {
              const title = (item.product_title || '').toLowerCase();
              const isJersey = title.includes('jersey') || title.includes('playera oficial');
              const props = item.properties || {};
              return isJersey && props['_promo_jersey'] === 'true';
            });

            if (jerseyQty <= 0) {
              // No jerseys available - remove promo jersey if exists
              if (existingPromoJersey) {
                const jerseyLine = cart.items.indexOf(existingPromoJersey) + 1;
                await fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ line: jerseyLine, quantity: 0 })
                });
              }
            } else if (existingPromoJersey) {
              // Promo jersey exists - update its quantity capped to available
              const jerseyLine = cart.items.indexOf(existingPromoJersey) + 1;
              await fetch('/cart/change.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  line: jerseyLine,
                  quantity: jerseyQty
                })
              });
            } else {
              // No promo jersey exists - add one with capped quantity
              await fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  id: jerseyData.jerseyVariantId,
                  quantity: jerseyQty,
                  properties: {
                    '_promo_jersey': 'true'
                  }
                })
              });
            }

            // Store jersey info in sessionStorage for registration form
            sessionStorage.setItem('jerseyDisponible', JSON.stringify({
              disponible: true,
              sede: jerseyData.sede,
              count: jerseyQty
            }));
          } catch (jerseyError) {
            console.error('Error handling jersey:', jerseyError);
          }
        }

        // Mostrar toast
        mostrarToast(quantity, categoriaName);

        // Actualizar badges del carrito
        await actualizarBadgesCarrito();
      } else {
        alert('Error al agregar al carrito. Intenta de nuevo.');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Error al agregar al carrito. Intenta de nuevo.');
    }

    // Restaurar boton
    btn.disabled = false;
    btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg> AGREGAR AL CARRITO`;
  }

  // ============ TOUR GUIADO ============
  const tourSteps = [
    {
      element: '.inscripcion__section',
      title: '1. Selecciona tu categoría',
      text: 'Toca la categoría que corresponde a tu edad. Verás un check verde cuando esté seleccionada.',
      position: 'bottom'
    },
    {
      element: '.inscripcion__price-card',
      title: '2. Revisa el precio',
      text: 'Aquí ves el precio actual de inscripción. Puede cambiar según la fase de venta.',
      position: 'bottom'
    },
    {
      element: '.inscripcion__cart-summary',
      title: '3. Tu carrito',
      text: 'Aquí verás todas las inscripciones que has agregado. Puedes inscribir personas en diferentes categorías.',
      position: 'bottom'
    },
    {
      element: '.inscripcion__quantity',
      title: '4. Elige la cantidad',
      text: '¿Inscribes a más personas en esta categoría? Ajusta la cantidad aquí.',
      position: 'bottom'
    },
    {
      element: '.inscripcion__actions',
      title: '5. Agrega al carrito o paga',
      text: 'Usa "Agregar al carrito" para inscribir en varias categorías, o "Pagar ahora" para ir directo al checkout.',
      position: 'bottom'
    }
  ];

  let currentTourStep = 0;
  let tourActive = false;

  function toggleHelpMenu() {
    const menu = document.getElementById('helpMenu');
    const bubble = document.getElementById('helpBubble');
    const tooltip = document.getElementById('helpTooltip');
    menu.classList.toggle('show');
    bubble.classList.toggle('active');
    // Ocultar tooltip cuando se abre el menú
    if (tooltip) tooltip.style.display = 'none';
  }

  function cerrarTooltipAyuda(event) {
    if (event) event.stopPropagation();
    const tooltip = document.getElementById('helpTooltip');
    if (tooltip) {
      tooltip.style.display = 'none';
      // Guardar solo para esta sesión
      sessionStorage.setItem('helpTooltipClosed', 'true');
    }
  }

  function abrirDesdeTooltip() {
    const tooltip = document.getElementById('helpTooltip');
    if (tooltip) tooltip.style.display = 'none';
    sessionStorage.setItem('helpTooltipClosed', 'true');
    toggleHelpMenu();
  }

  function mostrarTooltipAyuda() {
    const tooltip = document.getElementById('helpTooltip');
    if (tooltip) {
      tooltip.style.display = 'flex';
      // Auto-ocultar después de 10 segundos
      setTimeout(() => {
        if (tooltip && tooltip.style.display !== 'none') {
          tooltip.style.opacity = '0';
          setTimeout(() => {
            if (tooltip) {
              tooltip.style.display = 'none';
              tooltip.style.opacity = '1';
            }
          }, 300);
        }
      }, 10000);
    }
  }

  function iniciarTour() {
    toggleHelpMenu();
    currentTourStep = 0;
    tourActive = true;

    const overlay = document.getElementById('tourOverlay');
    const helpBubble = document.getElementById('helpBubble');

    overlay.classList.add('active');
    // Esconder la burbuja de ayuda durante el tour
    if (helpBubble) helpBubble.style.display = 'none';

    // Iniciar primer paso
    mostrarPasoTour();
  }

  function terminarTour() {
    tourActive = false;
    const overlay = document.getElementById('tourOverlay');
    const highlight = document.getElementById('tourHighlight');
    const tooltip = document.getElementById('tourTooltip');
    const helpBubble = document.getElementById('helpBubble');

    overlay.classList.remove('active');
    highlight.style.opacity = '0';
    tooltip.style.opacity = '0';

    // Mostrar la burbuja de ayuda de nuevo
    if (helpBubble) helpBubble.style.display = 'block';

    // Guardar que el usuario ya vio el tour
    localStorage.setItem('tourCompleted', 'true');
  }

  function posicionarHighlight() {
    if (!tourActive) return;

    const step = tourSteps[currentTourStep];
    const element = document.querySelector(step.element);
    if (!element) return;

    const rect = element.getBoundingClientRect();
    const highlight = document.getElementById('tourHighlight');
    const tooltip = document.getElementById('tourTooltip');

    // Posicionar highlight - FIXED usa coordenadas del viewport
    highlight.style.top = (rect.top - 10) + 'px';
    highlight.style.left = (rect.left - 10) + 'px';
    highlight.style.width = (rect.width + 20) + 'px';
    highlight.style.height = (rect.height + 20) + 'px';
    highlight.style.opacity = '1';

    // Posicionar tooltip - siempre en la parte inferior de la pantalla en mobile
    const isMobile = window.innerWidth <= 768;

    if (isMobile) {
      tooltip.style.top = 'auto';
      tooltip.style.bottom = '30px';
      tooltip.style.left = '16px';
      tooltip.style.right = '16px';
      tooltip.style.width = 'auto';
    } else {
      tooltip.style.bottom = 'auto';
      tooltip.style.right = 'auto';
      tooltip.style.width = '320px';

      // Posicionar cerca del elemento
      const tooltipTop = rect.bottom + 20;
      tooltip.style.top = Math.min(tooltipTop, window.innerHeight - 250) + 'px';
      tooltip.style.left = Math.max(16, Math.min(rect.left, window.innerWidth - 340)) + 'px';
    }

    tooltip.style.opacity = '1';
  }

  function mostrarPasoTour() {
    if (!tourActive) return;

    const step = tourSteps[currentTourStep];
    let element = document.querySelector(step.element);

    // Si el elemento no existe o no es visible, intentar con fallback
    if (!element || element.offsetParent === null || element.style.display === 'none') {
      if (step.fallback) {
        element = document.querySelector(step.fallback);
      }
    }

    // Si aún no hay elemento, saltar al siguiente paso
    if (!element || element.offsetParent === null) {
      console.log('Elemento no encontrado:', step.element);
      siguientePasoTour();
      return;
    }

    // Ocultar mientras hacemos scroll
    const highlight = document.getElementById('tourHighlight');
    const tooltip = document.getElementById('tourTooltip');
    highlight.style.opacity = '0';
    tooltip.style.opacity = '0';

    // Actualizar contenido del tooltip
    document.getElementById('tourStepNumber').textContent = `Paso ${currentTourStep + 1} de ${tourSteps.length}`;
    document.getElementById('tourTitle').textContent = step.title;
    document.getElementById('tourText').textContent = step.text;
    document.getElementById('tourProgress').style.width = ((currentTourStep + 1) / tourSteps.length * 100) + '%';

    // Cambiar texto del botón en último paso
    const nextBtn = document.getElementById('tourNextBtn');
    nextBtn.textContent = currentTourStep === tourSteps.length - 1 ? '¡Entendido!' : 'Siguiente';

    // Scroll al elemento - mostrar desde arriba con espacio para el header
    const headerOffset = 120;
    const elementPosition = element.getBoundingClientRect().top;
    const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

    window.scrollTo({
      top: offsetPosition,
      behavior: 'smooth'
    });

    // Esperar a que termine el scroll y posicionar
    setTimeout(() => {
      posicionarHighlight();
    }, 600);
  }

  function siguientePasoTour() {
    currentTourStep++;
    if (currentTourStep >= tourSteps.length) {
      terminarTour();
    } else {
      mostrarPasoTour();
    }
  }

  // Re-posicionar cuando el usuario hace scroll durante el tour
  let scrollTimeout;
  window.addEventListener('scroll', function() {
    if (tourActive) {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(posicionarHighlight, 100);
    }
  });

  // ============ DISCOUNT BAR - CHILILOVE ============
  function initPromoBanner() {
    const copyBtn = document.getElementById('copyDiscountBtn');
    if (!copyBtn) return;
    const discountCode = 'CHILILOVE';
    copyBtn.addEventListener('click', async function() {
      try {
        await navigator.clipboard.writeText(discountCode);
      } catch (err) {
        const textArea = document.createElement('textarea');
        textArea.value = discountCode;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
      }
      copyBtn.classList.add('copied');
      localStorage.setItem('discountCode', discountCode);
      setTimeout(() => {
        copyBtn.classList.remove('copied');
      }, 2000);
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    initDynamicPricing();
    initFomoInventory();
    actualizarBadgesCarrito();
    initPromoBanner();

    // Auto-seleccionar categoría si viene de una página de sede
    const preselected = sessionStorage.getItem('selectedCategory');
    if (preselected) {
      sessionStorage.removeItem('selectedCategory');
      const buttons = document.querySelectorAll('.inscripcion__cat-btn');
      buttons.forEach(function(btn) {
        if (btn.getAttribute('data-variant-title') === preselected) {
          selectCategoria(btn);
        }
      });
    }

    // Mostrar tooltip de ayuda después de 3 segundos
    setTimeout(mostrarTooltipAyuda, 3000);

    // Interceptar el formulario "PAGAR AHORA" para redirigir al carrito
    // Las inscripciones SIEMPRE deben pasar por el flujo: carrito → registro → checkout
    const form = document.getElementById('inscripcion-form');
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault(); // Siempre prevenir el submit directo a checkout

        const btn = form.querySelector('.inscripcion__btn--pay');
        if (btn) {
          btn.disabled = true;
          btn.textContent = 'Procesando...';
        }

        try {
          const variantId = document.getElementById('selectedVariantId').value;
          const quantity = parseInt(document.getElementById('quantity').value) || 1;

          // Agregar inscripcion al carrito via fetch
          const addResponse = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: variantId, quantity: quantity })
          });

          if (!addResponse.ok) {
            throw new Error('Error al agregar al carrito');
          }

          // Manejar jersey promo si aplica
          if (jerseyData && jerseyData.disponible && jerseyData.jerseyVariantId) {
            try {
              const cartResponse = await fetch('/cart.js');
              const cart = await cartResponse.json();

              const totalInscriptions = cart.items
                .filter(item => {
                  const title = (item.product_title || '').toLowerCase();
                  return title.includes('inscripcion') || title.includes('inscripción');
                })
                .reduce((total, item) => total + item.quantity, 0);

              let jerseyQty = totalInscriptions;
              try {
                const invResponse = await fetch('https://dhmexraces-webhooks.vercel.app/api/inventory');
                const invData = await invResponse.json();
                const sede = (jerseyData.sede || 'guanajuato').toLowerCase();
                const disponibles = invData.sedes?.[sede]?.playeras?.disponibles ?? 50;
                jerseyQty = Math.min(totalInscriptions, disponibles);
              } catch (invErr) {
                console.error('Error fetching inventory:', invErr);
              }

              const existingPromoJersey = cart.items.find(item => {
                const props = item.properties || {};
                return props['_promo_jersey'] === 'true';
              });

              if (jerseyQty <= 0) {
                if (existingPromoJersey) {
                  const jerseyLine = cart.items.indexOf(existingPromoJersey) + 1;
                  await fetch('/cart/change.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ line: jerseyLine, quantity: 0 })
                  });
                }
              } else if (existingPromoJersey) {
                const jerseyLine = cart.items.indexOf(existingPromoJersey) + 1;
                await fetch('/cart/change.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ line: jerseyLine, quantity: jerseyQty })
                });
              } else {
                await fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                    id: jerseyData.jerseyVariantId,
                    quantity: jerseyQty,
                    properties: { '_promo_jersey': 'true' }
                  })
                });
              }

              sessionStorage.setItem('jerseyDisponible', JSON.stringify({
                disponible: true,
                sede: jerseyData.sede,
                count: jerseyQty
              }));
            } catch (error) {
              console.error('Error agregando jersey promo:', error);
            }
          }

          // Redirigir al carrito (donde vera "Continuar al Registro")
          window.location.href = '/cart';
        } catch (error) {
          console.error('Error:', error);
          alert('Error al procesar. Intenta de nuevo.');
          if (btn) {
            btn.disabled = false;
            btn.textContent = 'PAGAR AHORA';
          }
        }
      });
    }
  });

  function initDynamicPricing() {
    const configEl = document.getElementById('pricingConfig');
    if (!configEl) return;
    try {
      const config = JSON.parse(configEl.textContent);
      if (!config.enabled) return;
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const validPhases = config.phases.filter(p => p.start && p.end && p.price > 0);
      if (validPhases.length === 0) return;
      let currentPhase = null;
      let currentPhaseIndex = -1;
      for (let i = 0; i < validPhases.length; i++) {
        const phase = validPhases[i];
        const startDate = new Date(phase.start);
        const endDate = new Date(phase.end);
        if (today >= startDate && today <= endDate) {
          currentPhase = phase;
          currentPhaseIndex = i;
          break;
        }
      }
      const priceEl = document.getElementById('productPrice');
      const badgeEl = document.getElementById('phaseBadge');
      if (currentPhase) {
        priceEl.textContent = '$' + currentPhase.price.toLocaleString('es-MX');
        if (badgeEl) badgeEl.textContent = currentPhase.label;
        document.querySelectorAll('.inscripcion__timeline-phase').forEach((el, idx) => {
          if (idx < currentPhaseIndex) el.classList.add('past');
          else if (idx === currentPhaseIndex) el.classList.add('current');
        });
      }
    } catch (e) {
      console.error('Error pricing:', e);
    }
  }

  async function initFomoInventory() {
    const configEl = document.getElementById('sedeConfig');
    if (!configEl) return;
    try {
      const config = JSON.parse(configEl.textContent);
      const productTitle = config.productTitle.toLowerCase();
      let sede = null;
      if (productTitle.includes('guanajuato')) sede = 'guanajuato';
      else if (productTitle.includes('puebla')) sede = 'puebla';
      else if (productTitle.includes('guadalajara')) sede = 'guadalajara';
      else if (productTitle.includes('ixtapan')) sede = 'ixtapan';
      else if (productTitle.includes('taxco')) sede = 'taxco';
      if (!sede) return;
      const response = await fetch(`${config.apiUrl}?sede=${sede}`);
      if (!response.ok) throw new Error('API error');
      const data = await response.json();
      if (!data.success) throw new Error(data.error);
      const container = document.getElementById('fomoContainer');
      const playerasEl = document.getElementById('fomoPlayeras');
      const medallasEl = document.getElementById('fomoMedallas');
      const playerasValueEl = document.getElementById('fomoPlayerasValue');
      const medallasValueEl = document.getElementById('fomoMedallasValue');

      // Store jersey availability for cart operations
      const playerasDisponibles = !data.playeras.agotadas && data.playeras.disponibles > 0;

      if (playerasDisponibles && config.jerseyHandles && config.jerseyHandles[sede]) {
        // Fetch jersey product info to get variant ID
        try {
          const jerseyHandle = config.jerseyHandles[sede];
          const jerseyResponse = await fetch(`/products/${jerseyHandle}.js`);
          if (jerseyResponse.ok) {
            const jerseyProduct = await jerseyResponse.json();
            // Get first available variant
            const availableVariant = jerseyProduct.variants.find(v => v.available);
            if (availableVariant) {
              jerseyData = {
                disponible: true,
                sede: sede,
                jerseyVariantId: availableVariant.id,
                jerseyProductTitle: jerseyProduct.title,
                playerasDisponibles: data.playeras.disponibles
              };
            }
          }
        } catch (jerseyError) {
          console.error('Error fetching jersey:', jerseyError);
        }
      }

      // Clear jersey availability if no jerseys left
      if (!playerasDisponibles) {
        sessionStorage.removeItem('jerseyDisponible');
      }

      if (container && playerasEl && medallasEl && playerasValueEl && medallasValueEl) {
        if (data.playeras.agotadas) {
          playerasValueEl.textContent = 'Agotadas';
          playerasEl.classList.add('inscripcion__fomo-badge--agotado');
        } else if (data.playeras.disponibles <= 10) {
          playerasValueEl.textContent = `${data.playeras.disponibles} de ${data.playeras.total} disponibles`;
          playerasEl.classList.add('inscripcion__fomo-badge--urgente');
        } else {
          playerasValueEl.textContent = `${data.playeras.disponibles} de ${data.playeras.total} disponibles`;
        }
        if (data.medallas.agotadas) {
          medallasValueEl.textContent = 'Agotadas';
          medallasEl.classList.add('inscripcion__fomo-badge--agotado');
        } else if (data.medallas.disponibles <= 20) {
          medallasValueEl.textContent = `${data.medallas.disponibles} de ${data.medallas.total} disponibles`;
          medallasEl.classList.add('inscripcion__fomo-badge--urgente');
        } else {
          medallasValueEl.textContent = `${data.medallas.disponibles} de ${data.medallas.total} disponibles`;
        }
        container.style.display = 'flex';
      }
    } catch (e) {
      console.error('Error FOMO:', e);
    }
  }
</script>

