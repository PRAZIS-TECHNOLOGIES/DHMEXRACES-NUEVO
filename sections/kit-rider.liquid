{% comment %}
  Kit del Rider - DHMEX SKELETON
  Kit items with cards (icon + badge + description + tag) + Prize cards + CTA
{% endcomment %}

<section class="section kit-section">
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label">{{ section.settings.subtitle | default: 'Incluido en tu inscripcion' }}</span>
        <h2 class="heading-lg">{{ section.settings.title | default: 'Kit del Rider' }}</h2>
      </div>
      {% if section.settings.description != blank %}
        <p class="body-text" style="max-width: 520px;">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    {% assign items = section.blocks | where: 'type', 'item' %}
    {% assign prizes = section.blocks | where: 'type', 'prize' %}

    {% if items.size > 0 %}
      <div class="kit-grid">
        {% for block in items %}
          <div class="kit-item reveal {% if block.settings.featured %}kit-item--featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="kit-item__icon">
              {% case block.settings.icon %}
                {% when 'medal' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M9 13L7 22L12 19L17 22L15 13"/></svg>
                {% when 'tshirt' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7L16 3H8L4 7L7 9V20H17V9L20 7Z"/></svg>
                {% when 'timer' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="13" r="8"/><path d="M12 9V13L15 15M10 2H14M12 2V5"/></svg>
                {% when 'plate' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M8 12H16M12 9V15"/></svg>
                {% when 'camera' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                {% when 'ambulance' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 10H14M12 8V12M3 15V7C3 5.9 3.9 5 5 5H15L19 9V15M3 15H19M3 15C3 16.1 3.9 17 5 17M19 15C19 16.1 19.9 17 21 17H19"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
                {% when 'beer' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 11H19C20.1 11 21 11.9 21 13V15C21 16.1 20.1 17 19 17H17M5 7H17V19C17 20.1 16.1 21 15 21H7C5.9 21 5 20.1 5 19V7ZM9 3V7M13 3V7"/></svg>
                {% when 'trophy' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H4C3.4 9 3 8.6 3 8V5C3 4.4 3.4 4 4 4H6M18 9H20C20.6 9 21 8.6 21 8V5C21 4.4 20.6 4 20 4H18M6 4H18V12C18 15.3 15.3 18 12 18C8.7 18 6 15.3 6 12V4ZM9 22H15M12 18V22"/></svg>
                {% when 'money' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1V23M17 5H9.5C7 5 5 7 5 9.5C5 12 7 14 9.5 14H14.5C17 14 19 16 19 18.5C19 21 17 23 14.5 23H7"/></svg>
                {% when 'star' %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {% else %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8V16M8 12H16"/></svg>
              {% endcase %}
            </div>
            <h3 class="kit-item__title">{{ block.settings.title }}</h3>
            {% if block.settings.badge != blank %}
              <span class="kit-item__badge">{{ block.settings.badge }}</span>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="kit-item__desc">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.sponsor != blank %}
              <span class="kit-item__sponsor">{{ block.settings.sponsor }}</span>
            {% endif %}
            {% if block.settings.tag != blank %}
              <span class="kit-item__tag">{{ block.settings.tag }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if prizes.size > 0 %}
      <div class="section__divider"></div>
      <div class="section__header">
        <div class="section__header-left">
          <span class="label">{{ section.settings.prizes_subtitle | default: 'Premios de la copa' }}</span>
          <h2 class="heading-md">{{ section.settings.prizes_title | default: 'Premiacion' }}</h2>
        </div>
      </div>
      <div class="prize-grid">
        {% for block in prizes %}
          <div class="prize-card reveal {% if block.settings.wide %}prize-card--wide{% endif %}" {{ block.shopify_attributes }}>
            <div class="prize-card__icon">
              {% if block.settings.icon == 'trophy' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H4C3.4 9 3 8.6 3 8V5C3 4.4 3.4 4 4 4H6M18 9H20C20.6 9 21 8.6 21 8V5C21 4.4 20.6 4 20 4H18M6 4H18V12C18 15.3 15.3 18 12 18C8.7 18 6 15.3 6 12V4ZM9 22H15M12 18V22"/></svg>
              {% elsif block.settings.icon == 'star' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {% else %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1V23M17 5H9.5C7 5 5 7 5 9.5C5 12 7 14 9.5 14H14.5C17 14 19 16 19 18.5C19 21 17 23 14.5 23H7"/></svg>
              {% endif %}
            </div>
            <span class="prize-card__category">{{ block.settings.category }}</span>
            {% if block.settings.description != blank %}
              <p class="prize-card__desc">{{ block.settings.description }}</p>
            {% endif %}
            <div class="prize-card__amount">
              <span class="prize-card__value">{{ block.settings.value }}</span>
              {% if block.settings.value_label != blank %}
                <span class="prize-card__label">{{ block.settings.value_label }}</span>
              {% endif %}
            </div>
            {% if block.settings.sponsor != blank %}
              <span class="prize-card__sponsor">{{ block.settings.sponsor }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.cta_text != blank %}
      <div class="kit-cta reveal">
        <a href="{{ section.settings.cta_link | default: '/#tickets' }}" class="btn btn--primary btn--large">{{ section.settings.cta_text }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Kit del Rider",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Incluido en tu inscripcion"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Kit del Rider"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Todo lo que incluye tu inscripcion a la copa nacional de downhill mas profesional de Mexico"
    },
    {
      "type": "text",
      "id": "prizes_subtitle",
      "label": "Subtitulo premios",
      "default": "Premios de la copa"
    },
    {
      "type": "text",
      "id": "prizes_title",
      "label": "Titulo premios",
      "default": "Premiacion"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del boton CTA",
      "default": "Inscribirse Ahora"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link del CTA"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item del Kit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "medal", "label": "Medalla" },
            { "value": "tshirt", "label": "Playera" },
            { "value": "timer", "label": "Cronometro" },
            { "value": "plate", "label": "Placa" },
            { "value": "camera", "label": "Camara" },
            { "value": "ambulance", "label": "Ambulancia" },
            { "value": "beer", "label": "Cerveza" },
            { "value": "trophy", "label": "Trofeo" },
            { "value": "money", "label": "Dinero" },
            { "value": "star", "label": "Estrella" }
          ],
          "default": "medal"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Medalla Finisher"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (quien lo recibe)",
          "info": "Ej: Todos los inscritos, Primeros 50"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripcion detallada"
        },
        {
          "type": "text",
          "id": "sponsor",
          "label": "Patrocinador",
          "info": "Ej: Powered by MULA PRIETA"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag inferior",
          "info": "Ej: 100 por sede, Incluido, +18 unicamente"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacado (ocupa 2 columnas)",
          "default": false
        }
      ]
    },
    {
      "type": "prize",
      "name": "Premio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "money", "label": "Dinero" },
            { "value": "trophy", "label": "Trofeo" },
            { "value": "star", "label": "Estrella" }
          ],
          "default": "money"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Categoria",
          "default": "Premio Efectivo Elite"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripcion",
          "info": "Detalle del premio y categorias elegibles"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Monto",
          "default": "$50,000 MXN"
        },
        {
          "type": "text",
          "id": "value_label",
          "label": "Etiqueta del monto",
          "default": "Total",
          "info": "Ej: Total, Por sede, Por etapa"
        },
        {
          "type": "text",
          "id": "sponsor",
          "label": "Patrocinador"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "label": "Ancho completo",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kit del Rider",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "medal",
            "title": "Medalla Conmemorativa",
            "badge": "Primeros 100 inscritos por sede",
            "description": "Medalla exclusiva de edicion limitada con diseno unico de la copa. Solo para los primeros 100 riders en inscribirse en cada sede.",
            "tag": "100 por sede"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "tshirt",
            "title": "Playera Oficial",
            "badge": "Primeros 50 inscritos",
            "description": "Playera oficial del evento con diseno exclusivo de cada sede. Material premium y corte deportivo.",
            "tag": "50 por sede"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "timer",
            "title": "Chip de Cronometraje",
            "badge": "Todos los participantes",
            "description": "Sistema de cronometraje profesional con chip individual. Al terminar tu bajada, marca tu chip en la computadora para registrar tu tiempo oficial.",
            "tag": "Incluido"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "plate",
            "title": "Race Plate",
            "badge": "Todos los participantes",
            "description": "Placa de competencia oficial con tu numero de corredor para montar en tu bici.",
            "tag": "Incluido"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "camera",
            "title": "Fotografia Profesional",
            "badge": "Practica y carrera",
            "description": "Cobertura fotografica profesional durante los dos dias del evento. Fotos disponibles para descargar gratis.",
            "tag": "Incluido"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "ambulance",
            "title": "Servicio Medico",
            "badge": "Tu seguridad es prioridad",
            "description": "Ambulancias y paramedicos disponibles durante el dia de entrenamiento y dia de carrera. Cobertura completa en pista.",
            "tag": "2 dias por sede"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "beer",
            "title": "Cerveza de Cortesia",
            "badge": "Mayores de 18 a\u00f1os",
            "description": "Porque despues de bajar, hay que celebrar. Cerveza gratis para todos los riders al finalizar la carrera.",
            "sponsor": "Powered by MULA PRIETA",
            "tag": "+18 unicamente",
            "featured": true
          }
        },
        {
          "type": "prize",
          "settings": {
            "icon": "money",
            "category": "Premio Efectivo Elite",
            "description": "Premio exclusivo para categoria Elite. $10,000 MXN por sede, dividido en las 5 etapas del copa nacional.",
            "value": "$50,000 MXN",
            "value_label": "Total"
          }
        },
        {
          "type": "prize",
          "settings": {
            "icon": "money",
            "category": "Premio Efectivo Junior",
            "description": "Premio exclusivo para categoria Junior. $5,000 MXN por sede, dividido en las 5 etapas del copa nacional.",
            "value": "$25,000 MXN",
            "value_label": "Total"
          }
        },
        {
          "type": "prize",
          "settings": {
            "icon": "money",
            "category": "Premio Efectivo Senior",
            "description": "Premio exclusivo para categoria Senior. $5,000 MXN por sede, dividido en las 5 etapas del copa nacional.",
            "value": "$25,000 MXN",
            "value_label": "Total"
          }
        },
        {
          "type": "prize",
          "settings": {
            "icon": "trophy",
            "category": "Premiacion en Especie",
            "description": "Productos premium para los ganadores de todas las categorias (excepto Elite) en cada sede de la copa.",
            "value": "$100,000 MXN",
            "value_label": "Por sede",
            "sponsor": "by MOTUL \u2022 SRAM \u2022 SCHWALBE \u2022 VITTORIA \u2022 GIRO \u2022 ALPINESTARS \u2022 RACE FACE \u2022 SYNCROS \u2022 ZEFAL",
            "wide": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
