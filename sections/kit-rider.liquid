{% comment %}
  Kit del Rider - DHMEX PRO
  Kit items with icons + Prize cards + CTA
{% endcomment %}

<section class="section kit-section">
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label">{{ section.settings.subtitle | default: 'Incluido en tu inscripcion' }}</span>
        <h2 class="heading-lg">{{ section.settings.title | default: 'Kit del Rider' }}</h2>
      </div>
      {% if section.settings.description != blank %}
        <p class="body-text" style="max-width: 480px;">{{ section.settings.description }}</p>
      {% endif %}
    </div>

    {% assign items = section.blocks | where: 'type', 'item' %}
    {% assign prizes = section.blocks | where: 'type', 'prize' %}

    {% if items.size > 0 %}
      <div class="kit-grid">
        {% for block in items %}
          <div class="kit-item reveal {% if block.settings.featured %}kit-item--featured{% endif %}" {{ block.shopify_attributes }}>
            <div class="kit-item__icon">
              {% case block.settings.icon %}
                {% when 'medal' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M9 13L7 22L12 19L17 22L15 13"/></svg>
                {% when 'tshirt' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7L16 3H8L4 7L7 9V20H17V9L20 7Z"/></svg>
                {% when 'timer' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="13" r="8"/><path d="M12 9V13L15 15M10 2H14M12 2V5"/></svg>
                {% when 'plate' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M8 12H16M12 9V15"/></svg>
                {% when 'camera' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                {% when 'ambulance' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 10H14M12 8V12M3 15V7C3 5.9 3.9 5 5 5H15L19 9V15M3 15H19M3 15C3 16.1 3.9 17 5 17M19 15C19 16.1 19.9 17 21 17H19"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
                {% when 'beer' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 11H19C20.1 11 21 11.9 21 13V15C21 16.1 20.1 17 19 17H17M5 7H17V19C17 20.1 16.1 21 15 21H7C5.9 21 5 20.1 5 19V7ZM9 3V7M13 3V7"/></svg>
                {% when 'trophy' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 9H4C3.4 9 3 8.6 3 8V5C3 4.4 3.4 4 4 4H6M18 9H20C20.6 9 21 8.6 21 8V5C21 4.4 20.6 4 20 4H18M6 4H18V12C18 15.3 15.3 18 12 18C8.7 18 6 15.3 6 12V4ZM9 22H15M12 18V22"/></svg>
                {% when 'money' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 1V23M17 5H9.5C7 5 5 7 5 9.5C5 12 7 14 9.5 14H14.5C17 14 19 16 19 18.5C19 21 17 23 14.5 23H7"/></svg>
                {% when 'star' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {% else %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8V16M8 12H16"/></svg>
              {% endcase %}
            </div>
            <div class="kit-item__text">
              <h3 class="kit-item__title">{{ block.settings.title }}</h3>
              {% if block.settings.description != blank %}
                <p class="kit-item__desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if prizes.size > 0 %}
      <div class="section__divider"></div>
      <div class="section__header">
        <div class="section__header-left">
          <span class="label">{{ section.settings.prizes_subtitle | default: 'Premios por sede' }}</span>
          <h2 class="heading-md">{{ section.settings.prizes_title | default: 'Premiacion' }}</h2>
        </div>
      </div>
      <div class="prize-grid">
        {% for block in prizes %}
          <div class="prize-card reveal" {{ block.shopify_attributes }}>
            <span class="prize-card__category">{{ block.settings.category }}</span>
            <span class="prize-card__value">{{ block.settings.value }}</span>
            {% if block.settings.sponsor != blank %}
              <span class="prize-card__sponsor">{{ block.settings.sponsor }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.cta_text != blank %}
      <div class="kit-cta reveal">
        <a href="{{ section.settings.cta_link | default: '/#tickets' }}" class="btn btn--primary btn--large">{{ section.settings.cta_text }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Kit del Rider",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Incluido en tu inscripcion"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Kit del Rider"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion"
    },
    {
      "type": "text",
      "id": "prizes_subtitle",
      "label": "Subtitulo premios",
      "default": "Premios por sede"
    },
    {
      "type": "text",
      "id": "prizes_title",
      "label": "Titulo premios",
      "default": "Premiacion"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del boton CTA",
      "default": "Inscribirse Ahora"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link del CTA"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item del Kit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "medal", "label": "Medalla" },
            { "value": "tshirt", "label": "Playera" },
            { "value": "timer", "label": "Cronometro" },
            { "value": "plate", "label": "Placa" },
            { "value": "camera", "label": "Camara" },
            { "value": "ambulance", "label": "Ambulancia" },
            { "value": "beer", "label": "Cerveza" },
            { "value": "trophy", "label": "Trofeo" },
            { "value": "money", "label": "Dinero" },
            { "value": "star", "label": "Estrella" }
          ],
          "default": "medal"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Medalla Finisher"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripcion"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Destacado (ocupa 2 columnas)",
          "default": false
        }
      ]
    },
    {
      "type": "prize",
      "name": "Premio",
      "settings": [
        {
          "type": "text",
          "id": "category",
          "label": "Categoria",
          "default": "1er Lugar"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Premio",
          "default": "$10,000 MXN"
        },
        {
          "type": "text",
          "id": "sponsor",
          "label": "Patrocinador"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kit del Rider",
      "blocks": [
        { "type": "item", "settings": { "icon": "medal", "title": "Medalla Finisher", "description": "Medalla conmemorativa para todos los que crucen la meta" } },
        { "type": "item", "settings": { "icon": "tshirt", "title": "Jersey Oficial", "description": "Jersey exclusivo de la sede" } },
        { "type": "item", "settings": { "icon": "timer", "title": "Cronometraje Profesional", "description": "Chip de cronometraje individual" } },
        { "type": "item", "settings": { "icon": "plate", "title": "Placa de Numero", "description": "Placa con tu numero de competidor" } },
        { "type": "item", "settings": { "icon": "camera", "title": "Fotos y Video", "description": "Cobertura profesional de la carrera" } },
        { "type": "item", "settings": { "icon": "ambulance", "title": "Servicio Medico", "description": "Ambulancia y paramedicos en pista" } },
        { "type": "item", "settings": { "icon": "beer", "title": "Cerveza de Cortesia", "description": "Una cerveza al cruzar la meta" } },
        { "type": "prize", "settings": { "category": "1er Lugar Elite/PRO", "value": "$15,000 MXN" } },
        { "type": "prize", "settings": { "category": "2do Lugar Elite/PRO", "value": "$10,000 MXN" } },
        { "type": "prize", "settings": { "category": "3er Lugar Elite/PRO", "value": "$5,000 MXN" } }
      ]
    }
  ]
}
{% endschema %}
