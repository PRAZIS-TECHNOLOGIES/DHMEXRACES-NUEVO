{% comment %}
  Race Dates Section - Dashed Card Style
  Editorial cards with dotted borders, no images
{% endcomment %}

<section class="section race-dates {% if section.settings.bg_image != blank %}race-dates--has-bg{% endif %}" id="sedes">
  {% if section.settings.bg_image != blank %}
    <div class="race-dates__bg race-dates__bg--desktop">
      <img src="{{ section.settings.bg_image | image_url: width: 2000 }}" alt="" loading="lazy">
    </div>
    <div class="race-dates__bg race-dates__bg--mobile">
      {% if section.settings.bg_image_mobile != blank %}
        <img src="{{ section.settings.bg_image_mobile | image_url: width: 1080 }}" alt="" loading="lazy">
      {% else %}
        <img src="{{ section.settings.bg_image | image_url: width: 1080 }}" alt="" loading="lazy">
      {% endif %}
    </div>
    <div class="race-dates__overlay"></div>
  {% endif %}
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label reveal">{{ section.settings.subtitle | default: 'Temporada 2026' }}</span>
        <h2 class="heading-lg reveal reveal--delay-1">{{ section.settings.title | default: 'Sedes & Inscripciones' }}</h2>
      </div>
    </div>

    <div class="sede-grid stagger-children">
      {% for block in section.blocks %}
        {% if block.type == 'race' %}
          <div class="sede-card reveal" {{ block.shopify_attributes }}>
            <div class="sede-card__top">
              <span class="sede-card__round">{{ block.settings.round | default: 'R1' }}</span>
              <span class="sede-card__status sede-card__status--{{ block.settings.status }}">
                {% case block.settings.status %}
                  {% when 'open' %}
                    <span class="sede-card__status-dot"></span>Abiertas
                  {% when 'upcoming' %}
                    Proximamente
                  {% when 'closed' %}
                    Cerrada
                {% endcase %}
              </span>
            </div>

            <h3 class="sede-card__title">{{ block.settings.title }}</h3>

            <div class="sede-card__meta">
              {% if block.settings.date != blank %}
                <span class="sede-card__meta-item">{{ block.settings.date }}</span>
              {% endif %}
              {% if block.settings.location != blank %}
                <span class="sede-card__meta-item">{{ block.settings.location }}</span>
              {% endif %}
              {% if block.settings.elevation != blank %}
                <span class="sede-card__meta-item">~ {{ block.settings.elevation }}</span>
              {% endif %}
            </div>

            {% if block.settings.description != blank %}
              <p class="sede-card__desc">{{ block.settings.description }}</p>
            {% endif %}

            <div class="sede-card__actions">
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="btn {% if block.settings.status == 'open' %}btn--primary{% else %}btn--outline{% endif %}">
                  {% if block.settings.status == 'open' %}Inscribirse{% else %}Ver Sede{% endif %}
                </a>
              {% endif %}
              {% if block.settings.status == 'closed' and block.settings.results_link != blank %}
                <a href="{{ block.settings.results_link }}" class="btn btn--outline">Ver Resultados</a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>


{% schema %}
{
  "name": "Sedes & Inscripciones",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de fondo (desktop)",
      "info": "Dejar vacio para fondo blanco"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Imagen de fondo (mobile vertical)",
      "info": "Imagen vertical para celular. Si no se agrega usa la de desktop"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Temporada 2026"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Sedes & Inscripciones"
    }
  ],
  "blocks": [
    {
      "type": "race",
      "name": "Sede",
      "settings": [
        {
          "type": "text",
          "id": "round",
          "label": "Ronda",
          "default": "R1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ciudad",
          "default": "Guanajuato"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Fecha",
          "default": "15 Mar 2026"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Ubicacion",
          "default": "Guanajuato, GTO"
        },
        {
          "type": "text",
          "id": "elevation",
          "label": "Elevacion",
          "default": "2,100 msnm"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripcion"
        },
        {
          "type": "select",
          "id": "status",
          "label": "Estado",
          "options": [
            { "value": "upcoming", "label": "Proximamente" },
            { "value": "open", "label": "Inscripciones Abiertas" },
            { "value": "closed", "label": "Cerrada" }
          ],
          "default": "upcoming"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link de inscripcion"
        },
        {
          "type": "url",
          "id": "results_link",
          "label": "Link a resultados"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sedes & Inscripciones",
      "blocks": [
        { "type": "race", "settings": { "round": "R1", "title": "Guanajuato", "date": "21-22 Feb 2026", "location": "Guanajuato, GTO", "elevation": "2,100 msnm", "status": "closed" } },
        { "type": "race", "settings": { "round": "R2", "title": "Puebla", "date": "21-22 Mar 2026", "location": "Puebla, PUE", "elevation": "2,160 msnm", "status": "open" } },
        { "type": "race", "settings": { "round": "R3", "title": "Guadalajara", "date": "30-31 May 2026", "location": "Guadalajara, JAL", "status": "upcoming" } },
        { "type": "race", "settings": { "round": "R4", "title": "Ixtapan de la Sal", "date": "18-19 Jul 2026", "location": "Ixtapan de la Sal, MEX", "status": "upcoming" } },
        { "type": "race", "settings": { "round": "R5", "title": "Taxco", "date": "17-18 Oct 2026", "location": "Taxco, GRO", "status": "upcoming" } }
      ]
    }
  ]
}
{% endschema %}
