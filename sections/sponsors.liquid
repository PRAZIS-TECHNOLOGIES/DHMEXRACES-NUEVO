<section id="sponsors" class="sponsors">
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label reveal">{{ section.settings.label | default: 'Presentado por' }}</span>
        <h2 class="heading-lg reveal reveal--delay-1">{{ section.settings.heading | default: 'Sponsors' }}</h2>
      </div>
    </div>

    <div class="sponsors__grid stagger-children">
      {% for block in section.blocks %}
        <div class="sponsor reveal" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            <img
              src="{{ block.settings.logo | image_url: width: 240 }}"
              alt="{{ block.settings.name }}"
              loading="lazy"
            >
          {% elsif block.settings.logo_url != blank %}
            <img
              src="{{ block.settings.logo_url }}"
              alt="{{ block.settings.name }}"
              loading="lazy"
            >
          {% else %}
            <span class="heading-sm" style="opacity: 0.4;">{{ block.settings.name }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sponsors",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Presentado por"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Sponsors"
    }
  ],
  "blocks": [
    {
      "type": "sponsor",
      "name": "Sponsor",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Sponsor"
        },
        {
          "type": "text",
          "id": "logo_url",
          "label": "URL externa del logo (PNG)"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL del sponsor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sponsors",
      "blocks": [
        { "type": "sponsor", "settings": { "name": "SCOTT" } },
        { "type": "sponsor", "settings": { "name": "SHIMANO" } },
        { "type": "sponsor", "settings": { "name": "RED BULL" } },
        { "type": "sponsor", "settings": { "name": "MOTUL" } },
        { "type": "sponsor", "settings": { "name": "SRAM" } },
        { "type": "sponsor", "settings": { "name": "SCHWALBE" } },
        { "type": "sponsor", "settings": { "name": "FOX FACTORY" } },
        { "type": "sponsor", "settings": { "name": "VITTORIA" } },
        { "type": "sponsor", "settings": { "name": "LAZER" } },
        { "type": "sponsor", "settings": { "name": "ALPINESTARS" } }
      ]
    }
  ]
}
{% endschema %}
