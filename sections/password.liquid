<section class="section" style="min-height: 60vh; display: flex; align-items: center;">
  <div class="container" style="text-align: center;">
    <h1 class="heading-xl">DHMEX<span class="accent">RACES</span></h1>
    <p class="body-text" style="margin: var(--space-md) 0;">{{ 'password.title' | t }}</p>
    {% form 'storefront_password' %}
      <div style="display: flex; gap: 8px; max-width: 400px; margin: 0 auto;">
        <input type="password" name="password" placeholder="{{ 'password.password' | t }}"
          style="flex: 1; padding: 10px 14px; background: var(--bg-secondary); border: 1px solid rgba(0,0,0,0.1); border-radius: 6px; color: var(--text-primary); font-family: var(--font-body);">
        <button type="submit" class="btn btn--primary">{{ 'password.enter' | t }}</button>
      </div>
      {% if form.errors %}
        <p style="color: var(--accent); margin-top: var(--space-sm);">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
