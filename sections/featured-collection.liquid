<section id="{{ section.settings.anchor_id | default: 'merch' }}" class="section section--alt">
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label reveal">{{ section.settings.label | default: 'Merch' }}</span>
        <h2 class="heading-lg reveal reveal--delay-1">{{ section.settings.heading | default: 'Merch oficial' }}</h2>
      </div>
      {% if section.settings.collection != blank %}
        <a href="{{ collections[section.settings.collection].url }}" class="btn btn--outline reveal">
          Ver todo
        </a>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      <div class="products-grid stagger-children">
        {% for product in collections[section.settings.collection].products limit: section.settings.products_count %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
    {% else %}
      <!-- Demo placeholders -->
      <div class="products-grid stagger-children">
        {% assign demo_products = 'Jersey DHMEX 2026,Hoodie DHMEX Black,Gorra DHMEX Snapback,Playera DHMEX Riders,Calcetines DHMEX Pack,Sticker Pack DHMEX' | split: ',' %}
        {% assign demo_prices = '$899,$1,299,$549,$599,$299,$199' | split: ',' %}
        {% for title in demo_products limit: 6 %}
          <div class="product-card reveal">
            <div class="product-card__image">
              <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #1a1a1a, #2a2a2a); display: flex; align-items: center; justify-content: center;">
                <span class="label" style="opacity: 0.3;">{{ title }}</span>
              </div>
            </div>
            <div class="product-card__info">
              <span class="product-card__vendor">DHMEXRACES</span>
              <h3 class="product-card__title">{{ title }}</h3>
              <span class="product-card__price">{{ demo_prices[forloop.index0] }} MXN</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Coleccion Destacada",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "ID de ancla",
      "default": "merch"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Merch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Merch oficial"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Coleccion"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Productos a mostrar",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Coleccion Destacada"
    }
  ]
}
{% endschema %}
