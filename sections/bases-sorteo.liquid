{% comment %}
  Sorteo FOX 40 - DHMEXRACES
  Editorial design with Fox Factory Orange #F26522 accents
  Animated prize image, split hero, visual bases
{% endcomment %}

<style>
  :root {
    --fox: #F26522;
    --fox-light: rgba(242, 101, 34, 0.07);
    --fox-border: rgba(242, 101, 34, 0.2);
    --fox-glow: rgba(242, 101, 34, 0.15);
  }

  .sorteo {
    padding: calc(var(--header-height) + var(--space-md)) 0 var(--space-md);
    overflow: hidden;
  }

  /* ── HERO ── */
  .sorteo__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
    min-height: auto;
    padding: var(--space-lg) var(--space-md);
    background: var(--bg-secondary);
    border-radius: 12px;
    margin-bottom: var(--space-md);
  }
  @media (max-width: 768px) {
    .sorteo__hero {
      grid-template-columns: 1fr;
      min-height: auto;
      text-align: center;
      padding: var(--space-lg);
    }
  }
  .sorteo__hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fox);
    border: 1px solid var(--fox-border);
    background: var(--fox-light);
    margin-bottom: var(--space-md);
  }
  .sorteo__hero-pre {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: var(--space-xs);
  }
  .sorteo__hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-md);
  }
  .sorteo__hero-title span {
    color: var(--fox);
  }
  .sorteo__hero-value {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 800;
    color: var(--fox);
    margin-bottom: 4px;
  }
  .sorteo__hero-model {
    font-size: 13px;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-md);
  }
  .sorteo__hero-cta-line {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  @media (max-width: 768px) {
    .sorteo__hero-cta-line { justify-content: center; }
  }
  .sorteo__hero-cta-line .sorteo__pill {
    padding: 8px 20px;
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    background: var(--fox);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .sorteo__hero-cta-line .sorteo__pill:hover { opacity: 0.85; }
  .sorteo__hero-cta-line span {
    font-size: 12px;
    color: var(--text-secondary);
  }

  /* Image container with float animation */
  .sorteo__hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sorteo__hero-img-wrap {
    position: relative;
    animation: sorteoFloat 4s ease-in-out infinite;
  }
  .sorteo__hero-img-wrap img {
    max-width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.12));
  }
  .sorteo__hero-img-glow {
    position: absolute;
    inset: 10%;
    background: radial-gradient(circle, var(--fox-glow) 0%, transparent 70%);
    border-radius: 50%;
    z-index: -1;
    filter: blur(40px);
  }
  @keyframes sorteoFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }

  /* ── PARTICIPATE ── */
  .sorteo__participate {
    padding: var(--space-md) 0;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .sorteo__participate-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fox);
    margin-bottom: var(--space-xs);
  }
  .sorteo__participate-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }
  .sorteo__steps {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: var(--space-sm);
    align-items: center;
    padding: var(--space-md);
    background: var(--bg-secondary);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
  }
  @media (max-width: 768px) {
    .sorteo__steps {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-md);
    }
    .sorteo__step-divider { display: none; }
  }
  .sorteo__step {
    text-align: center;
    padding: var(--space-sm);
  }
  .sorteo__step-tag {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #22C55E;
    margin-bottom: 6px;
  }
  .sorteo__step-tag--fire {
    color: var(--fox);
  }
  .sorteo__step-sede {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
  }
  .sorteo__step-boleto {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 4px;
  }
  .sorteo__step-divider {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 800;
    color: rgba(0,0,0,0.15);
  }
  .sorteo__step--combo .sorteo__step-sede {
    color: var(--fox);
  }
  .sorteo__step-note {
    font-size: 12px;
    color: var(--text-secondary);
    text-align: center;
    margin-top: var(--space-md);
  }

  /* ── INFO STRIP ── */
  .sorteo__strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 12px;
    overflow: hidden;
    margin: var(--space-md) 0;
  }
  @media (max-width: 768px) {
    .sorteo__strip {
      grid-template-columns: 1fr;
    }
  }
  .sorteo__strip-item {
    padding: var(--space-md);
    background: var(--bg-primary);
    text-align: center;
  }
  .sorteo__strip-label {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fox);
    margin-bottom: var(--space-sm);
  }
  .sorteo__strip-big {
    font-family: var(--font-heading);
    font-size: 26px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.1;
  }
  .sorteo__strip-sub {
    font-size: 13px;
    color: var(--text-secondary);
    margin-top: 4px;
  }
  .sorteo__strip-foot {
    font-size: 11px;
    color: var(--text-secondary);
    margin-top: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  /* ── BASES ── */
  .sorteo__bases-section {
    padding: var(--space-md) 0;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .sorteo__bases-label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fox);
    margin-bottom: var(--space-xs);
  }
  .sorteo__bases-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .sorteo__bases-sub {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }
  .sorteo__bases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
  }
  @media (max-width: 768px) {
    .sorteo__bases-grid {
      grid-template-columns: 1fr;
    }
  }
  .sorteo__base {
    padding: var(--space-md);
    border-left: 2px solid var(--fox-border);
    transition: border-color 0.15s ease;
  }
  .sorteo__base:hover {
    border-left-color: var(--fox);
  }
  .sorteo__base-num {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    color: var(--fox);
    letter-spacing: 0.08em;
    margin-bottom: 6px;
  }
  .sorteo__base-title {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .sorteo__base-text {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── CTA ── */
  .sorteo__cta {
    margin-top: var(--space-md);
    padding: var(--space-lg) var(--space-md);
    text-align: center;
    background: var(--text-primary);
    color: #fff;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }
  .sorteo__cta::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, var(--fox) 0%, transparent 70%);
    opacity: 0.15;
    border-radius: 50%;
  }
  .sorteo__cta-label {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fox);
    margin-bottom: var(--space-sm);
    position: relative;
  }
  .sorteo__cta-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
    position: relative;
  }
  .sorteo__cta-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    margin-bottom: var(--space-md);
    position: relative;
  }
  .sorteo__cta .btn--fox {
    display: inline-block;
    padding: 16px 40px;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    background: var(--fox);
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    position: relative;
  }
  .sorteo__cta .btn--fox:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(242, 101, 34, 0.3);
  }

  .sorteo__footer {
    text-align: center;
    margin-top: var(--space-lg);
    font-size: 11px;
    color: var(--text-secondary);
  }
</style>

<section class="sorteo">
  <div class="container">

    {%- comment -%} ── HERO ── {%- endcomment -%}
    <div class="sorteo__hero">
      <div>
        <div class="sorteo__hero-badge">Sorteo Oficial 2026</div>
        <div class="sorteo__hero-pre">Gana una</div>
        <h1 class="sorteo__hero-title">FOX <span>40</span></h1>
        <div class="sorteo__hero-value">$50,000 MXN</div>
        <div class="sorteo__hero-model">FOX 40 Factory GRIP 2 — Nueva, en caja, sin abrir</div>
        <div class="sorteo__hero-cta-line">
          <a href="{{ section.settings.cta_link | default: '/#sedes' }}" class="sorteo__pill">Inscribirse</a>
          <span>Cada inscripcion = 1 boleto</span>
        </div>
      </div>
      <div class="sorteo__hero-visual">
        {% if section.settings.prize_image != blank %}
          <div class="sorteo__hero-img-wrap">
            <div class="sorteo__hero-img-glow"></div>
            <img
              src="{{ section.settings.prize_image | image_url: width: 800 }}"
              alt="FOX 40 Factory GRIP 2"
              loading="eager"
            >
          </div>
        {% else %}
          <div class="sorteo__hero-img-wrap" style="padding: var(--space-xl); text-align: center;">
            <div class="sorteo__hero-img-glow"></div>
            <div style="font-family: var(--font-heading); font-size: clamp(3rem, 6vw, 5rem); font-weight: 900; color: var(--fox); opacity: 0.2; text-transform: uppercase;">FOX 40</div>
          </div>
        {% endif %}
      </div>
    </div>

    {%- comment -%} ── COMO PARTICIPAR ── {%- endcomment -%}
    <div class="sorteo__participate">
      <div class="sorteo__participate-label">Como participar</div>
      <div class="sorteo__participate-title">Obtén tus boletos</div>

      <div class="sorteo__steps">
        <div class="sorteo__step">
          <div class="sorteo__step-tag">✓ Inscribete a</div>
          <div class="sorteo__step-sede">Guanajuato</div>
          <div class="sorteo__step-boleto">= 1 boleto</div>
        </div>
        <div class="sorteo__step-divider">+</div>
        <div class="sorteo__step">
          <div class="sorteo__step-tag">✓ Inscribete a</div>
          <div class="sorteo__step-sede">Puebla</div>
          <div class="sorteo__step-boleto">= 1 boleto</div>
        </div>
        <div class="sorteo__step-divider">=</div>
        <div class="sorteo__step sorteo__step--combo">
          <div class="sorteo__step-tag sorteo__step-tag--fire">Ambas fechas</div>
          <div class="sorteo__step-sede">2 boletos</div>
          <div class="sorteo__step-boleto">Doble oportunidad</div>
        </div>
      </div>
      <p class="sorteo__step-note">Tu numero se asigna automaticamente al inscribirte • Max 2 boletos por rider</p>
    </div>

    {%- comment -%} ── INFO STRIP ── {%- endcomment -%}
    <div class="sorteo__strip">
      <div class="sorteo__strip-item">
        <div class="sorteo__strip-label">Fecha del Sorteo</div>
        <div class="sorteo__strip-big">22 Marzo</div>
        <div class="sorteo__strip-sub">2026 — Sede Puebla</div>
        <div class="sorteo__strip-foot">EN VIVO al finalizar la carrera</div>
      </div>
      <div class="sorteo__strip-item">
        <div class="sorteo__strip-label">El Premio</div>
        <div class="sorteo__strip-big">FOX 40</div>
        <div class="sorteo__strip-sub">Factory GRIP 2</div>
        <div class="sorteo__strip-foot">Valor: $50,000 MXN</div>
      </div>
      <div class="sorteo__strip-item">
        <div class="sorteo__strip-label">Transmision</div>
        <div class="sorteo__strip-big">En Vivo</div>
        <div class="sorteo__strip-sub">@dhmex_races</div>
        <div class="sorteo__strip-foot">Grabacion disponible</div>
      </div>
    </div>

    {%- comment -%} ── BASES LEGALES ── {%- endcomment -%}
    <div class="sorteo__bases-section">
      <div class="sorteo__bases-label">Terminos y Condiciones</div>
      <div class="sorteo__bases-title">Bases Oficiales</div>
      <div class="sorteo__bases-sub">Copa Scott DHMEXRACES 2026</div>

      <div class="sorteo__bases-grid">
        {% for block in section.blocks %}
          {% if block.type == 'base' %}
            <div class="sorteo__base" {{ block.shopify_attributes }}>
              <div class="sorteo__base-num">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</div>
              <h3 class="sorteo__base-title">{{ block.settings.title }}</h3>
              <div class="sorteo__base-text">{{ block.settings.content }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {%- comment -%} ── CTA ── {%- endcomment -%}
    <div class="sorteo__cta">
      <div class="sorteo__cta-label">Sorteo FOX 40</div>
      <div class="sorteo__cta-heading">Inscribete y Participa</div>
      <div class="sorteo__cta-desc">Cada inscripcion a Guanajuato o Puebla = 1 boleto automatico</div>
      <a href="{{ section.settings.cta_link | default: '/#sedes' }}" class="btn--fox">
        {{ section.settings.cta_text | default: 'Inscribirse Ahora' }}
      </a>
    </div>

    <div class="sorteo__footer">Ultima actualizacion: 13 de enero de 2026</div>
  </div>
</section>

{% schema %}
{
  "name": "Sorteo FOX 40",
  "settings": [
    {
      "type": "image_picker",
      "id": "prize_image",
      "label": "Imagen del premio",
      "info": "Foto de la FOX 40. Se anima con efecto flotante."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto boton CTA",
      "default": "Inscribirse Ahora"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link CTA"
    }
  ],
  "blocks": [
    {
      "type": "base",
      "name": "Base Legal",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titulo"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Contenido"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sorteo FOX 40",
      "blocks": []
    }
  ]
}
{% endschema %}
