<section id="gallery" class="section">
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label reveal">{{ section.settings.label | default: 'Highlights' }}</span>
        <h2 class="heading-lg reveal reveal--delay-1">{{ section.settings.heading | default: 'Temporadas anteriores' }}</h2>
      </div>
    </div>
  </div>

  <div class="gallery__grid gallery__grid--asymmetric stagger-children">
    {% for block in section.blocks %}
      <div class="gallery__item reveal" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.caption | default: 'DHMEXRACES' }}"
            loading="lazy"
          >
        {% elsif block.settings.image_url != blank %}
          <img
            src="{{ block.settings.image_url }}"
            alt="{{ block.settings.caption | default: 'DHMEXRACES' }}"
            loading="lazy"
          >
        {% else %}
          <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #1a1a1a, #252525);"></div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Galeria",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Highlights"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Temporadas anteriores"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Imagen",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "DHMEXRACES"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "URL externa de imagen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galeria",
      "blocks": [
        { "type": "image", "settings": { "caption": "Downhill Guanajuato" } },
        { "type": "image", "settings": { "caption": "Podium Elite" } },
        { "type": "image", "settings": { "caption": "Pista Taxco" } },
        { "type": "image", "settings": { "caption": "Pilotos en accion" } },
        { "type": "image", "settings": { "caption": "Mecanica neutral Shimano" } },
        { "type": "image", "settings": { "caption": "Premiacion" } },
        { "type": "image", "settings": { "caption": "Publico DHMEX" } },
        { "type": "image", "settings": { "caption": "Full send" } }
      ]
    }
  ]
}
{% endschema %}
