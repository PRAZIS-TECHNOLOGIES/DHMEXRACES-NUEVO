<section class="hero">
  <div class="hero__bg">
    {% if section.settings.bg_mode == 'video' %}
      {%- comment -%} MODE: YouTube Video — horizontal (desktop) + vertical (mobile) {%- endcomment -%}
      {% if section.settings.youtube_horizontal != blank %}
        {% assign yt_h = section.settings.youtube_horizontal %}
        {% if yt_h contains 'watch?v=' %}
          {% assign yt_h_id = yt_h | split: 'watch?v=' | last | split: '&' | first %}
        {% elsif yt_h contains 'youtu.be/' %}
          {% assign yt_h_id = yt_h | split: 'youtu.be/' | last | split: '?' | first %}
        {% elsif yt_h contains '/shorts/' %}
          {% assign yt_h_id = yt_h | split: '/shorts/' | last | split: '?' | first %}
        {% else %}
          {% assign yt_h_id = yt_h %}
        {% endif %}
        <iframe
          class="hero__yt hero__yt--desktop"
          src="https://www.youtube.com/embed/{{ yt_h_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_h_id }}&controls=0&showinfo=0&modestbranding=1&rel=0&playsinline=1&enablejsapi=1&iv_load_policy=3&disablekb=1&start={{ section.settings.yt_start | default: 0 }}"
          frameborder="0"
          allow="autoplay; encrypted-media"
          allowfullscreen
        ></iframe>
      {% endif %}
      {% if section.settings.youtube_vertical != blank %}
        {% assign yt_v = section.settings.youtube_vertical %}
        {% if yt_v contains 'watch?v=' %}
          {% assign yt_v_id = yt_v | split: 'watch?v=' | last | split: '&' | first %}
        {% elsif yt_v contains 'youtu.be/' %}
          {% assign yt_v_id = yt_v | split: 'youtu.be/' | last | split: '?' | first %}
        {% elsif yt_v contains '/shorts/' %}
          {% assign yt_v_id = yt_v | split: '/shorts/' | last | split: '?' | first %}
        {% else %}
          {% assign yt_v_id = yt_v %}
        {% endif %}
        <iframe
          class="hero__yt hero__yt--mobile"
          src="https://www.youtube.com/embed/{{ yt_v_id }}?autoplay=1&mute=1&loop=1&playlist={{ yt_v_id }}&controls=0&showinfo=0&modestbranding=1&rel=0&playsinline=1&enablejsapi=1&iv_load_policy=3&disablekb=1&start={{ section.settings.yt_start | default: 0 }}"
          frameborder="0"
          allow="autoplay; encrypted-media"
          allowfullscreen
        ></iframe>
      {% endif %}
    {% elsif section.settings.bg_mode == 'gallery' %}
      {%- comment -%} MODE: Photo Gallery — epic collage mosaic {%- endcomment -%}
      {% assign gallery_images = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'gallery_image' and block.settings.image != blank %}
          {% assign gallery_images = gallery_images | plus: 1 %}
        {% endif %}
      {% endfor %}

      {% if gallery_images > 0 %}
        <div class="hero__gallery">
          {% for block in section.blocks %}
            {% if block.type == 'gallery_image' and block.settings.image != blank %}
              <div class="hero__gallery-item" {{ block.shopify_attributes }}>
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.alt | default: 'DHMEX Races' }}"
                  loading="eager"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="hero__gallery hero__gallery--placeholder">
          {% for i in (1..8) %}
            <div class="hero__gallery-item hero__gallery-placeholder-item">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #FFFFFF 0%, #F5F5F5 50%, #FFFFFF 100%);"></div>
    {% endif %}
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <div class="hero__tag reveal">
      <span class="tag tag--accent">{{ section.settings.tag | default: 'TEMPORADA 2026 — 5 SEDES' }}</span>
    </div>

    <h1 class="hero__title heading-xl reveal reveal--delay-1">
      {% if section.settings.heading_pre != blank %}
        <span class="hero__title-pre">{{ section.settings.heading_pre }}</span>
      {% endif %}
      {{ section.settings.heading | default: 'DHMEX' }}
      <span class="hero__races">{{ section.settings.heading_accent | default: 'RACES' }}</span>
    </h1>

    <div class="hero__info reveal reveal--delay-2">
      <div class="hero__info-item">
        <span class="hero__info-label">Proxima sede</span>
        <span class="hero__info-value">{{ settings.event_location }}</span>
      </div>
      <div class="hero__info-item">
        <span class="hero__info-label">Fecha</span>
        <span class="hero__info-value">{{ section.settings.date_display | default: '21-22 MARZO 2026' }}</span>
      </div>
      <div class="hero__info-item">
        <span class="hero__info-label">Premios</span>
        <span class="hero__info-value">{{ section.settings.prize_display | default: '$530,000 MXN' }}</span>
      </div>
    </div>

    <!-- Countdown -->
    <div class="countdown reveal reveal--delay-3" data-countdown="{{ settings.event_date }}T08:00:00">
      <div class="countdown__item">
        <div class="countdown__number" data-days>00</div>
        <div class="countdown__label">Dias</div>
      </div>
      <div class="countdown__item">
        <div class="countdown__number" data-hours>00</div>
        <div class="countdown__label">Horas</div>
      </div>
      <div class="countdown__item">
        <div class="countdown__number" data-mins>00</div>
        <div class="countdown__label">Min</div>
      </div>
      <div class="countdown__item">
        <div class="countdown__number" data-secs>00</div>
        <div class="countdown__label">Seg</div>
      </div>
    </div>

    <div class="hero__actions reveal reveal--delay-4" style="margin-top: var(--space-md);">
      <a href="/#sedes" class="btn btn--primary btn--large">Inscribirme ahora</a>
      <a href="#about" class="btn btn--outline btn--large">Conocer mas</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Fondo del Hero"
    },
    {
      "type": "select",
      "id": "bg_mode",
      "label": "Tipo de fondo",
      "options": [
        { "value": "video", "label": "Video YouTube" },
        { "value": "gallery", "label": "Galeria de fotos" }
      ],
      "default": "gallery"
    },
    {
      "type": "header",
      "content": "Video YouTube"
    },
    {
      "type": "text",
      "id": "youtube_horizontal",
      "label": "YouTube horizontal (desktop)",
      "info": "URL del video horizontal para pantallas grandes"
    },
    {
      "type": "text",
      "id": "youtube_vertical",
      "label": "YouTube vertical (mobile)",
      "info": "URL del video vertical para celulares"
    },
    {
      "type": "range",
      "id": "yt_start",
      "label": "Segundo de inicio",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag superior",
      "default": "TEMPORADA 2026 — 5 SEDES"
    },
    {
      "type": "text",
      "id": "heading_pre",
      "label": "Titulo (linea superior)",
      "default": "COPA SCOTT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo (parte 1)",
      "default": "DHMEX"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Titulo (parte accent)",
      "default": "RACES"
    },
    {
      "type": "text",
      "id": "date_display",
      "label": "Fecha visible",
      "default": "21-22 MARZO 2026"
    },
    {
      "type": "text",
      "id": "prize_display",
      "label": "Premios visibles",
      "default": "$530,000 MXN"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Foto",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
