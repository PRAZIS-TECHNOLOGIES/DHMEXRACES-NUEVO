<section id="calendar" class="horizontal-stats">
  <div class="horizontal-stats__track">
    {% for block in section.blocks %}
      <div class="horizontal-stats__card" {{ block.shopify_attributes }}>
        <div class="horizontal-stats__number">{{ block.settings.number }}</div>
        <div class="horizontal-stats__text">{{ block.settings.text }}</div>
      </div>
    {% endfor %}

    {% comment %} ── Elevation Profile ── {% endcomment %}
    {% if section.blocks.size >= 5 %}
      <div class="elevation-profile">
        <div class="elevation-profile__chart">
          <svg viewBox="0 0 1200 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="elev-back" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(26,26,26,0.08)" />
                <stop offset="100%" stop-color="rgba(26,26,26,0)" />
              </linearGradient>
              <linearGradient id="elev-mid" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(26,26,26,0.14)" />
                <stop offset="100%" stop-color="rgba(26,26,26,0)" />
              </linearGradient>
              <linearGradient id="elev-front" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(26,26,26,0.22)" />
                <stop offset="100%" stop-color="rgba(26,26,26,0)" />
              </linearGradient>
            </defs>
            <line x1="0" y1="50" x2="1200" y2="50" stroke="rgba(0,0,0,0.06)" stroke-width="0.5" />
            <line x1="0" y1="100" x2="1200" y2="100" stroke="rgba(0,0,0,0.06)" stroke-width="0.5" />
            <line x1="0" y1="150" x2="1200" y2="150" stroke="rgba(0,0,0,0.06)" stroke-width="0.5" />
            <path d="M0,135 C60,128 110,85 180,78 C250,72 310,105 400,112 C490,118 540,72 620,65 C700,58 760,95 850,100 C940,105 990,78 1060,72 C1130,68 1170,105 1200,120 L1200,200 L0,200 Z" fill="url(#elev-back)" />
            <path d="M0,148 C40,140 80,58 150,42 C200,32 240,100 300,118 C360,132 400,48 460,35 C520,22 560,95 640,115 C700,128 740,52 810,40 C870,30 910,90 980,108 C1040,122 1080,50 1140,38 C1180,30 1200,80 1200,105 L1200,200 L0,200 Z" fill="url(#elev-mid)" />
            <path d="M0,155 C20,150 50,80 80,55 C100,38 115,28 120,25 C125,22 140,30 160,50 C185,78 210,115 240,125 C270,135 300,70 330,48 C345,38 355,30 360,26 C365,22 380,35 400,58 C430,95 455,130 480,140 C505,148 540,105 565,85 C580,75 592,68 600,62 C608,56 625,65 645,82 C670,105 695,118 720,122 C745,125 775,82 800,62 C820,48 832,38 840,32 C848,26 860,35 880,55 C910,88 940,120 960,130 C980,138 1010,95 1040,72 C1060,58 1072,48 1080,42 C1088,36 1100,42 1120,60 C1145,85 1175,130 1200,155 L1200,200 L0,200 Z" fill="url(#elev-front)" />
            <path d="M0,155 C20,150 50,80 80,55 C100,38 115,28 120,25 C125,22 140,30 160,50 C185,78 210,115 240,125 C270,135 300,70 330,48 C345,38 355,30 360,26 C365,22 380,35 400,58 C430,95 455,130 480,140 C505,148 540,105 565,85 C580,75 592,68 600,62 C608,56 625,65 645,82 C670,105 695,118 720,122 C745,125 775,82 800,62 C820,48 832,38 840,32 C848,26 860,35 880,55 C910,88 940,120 960,130 C980,138 1010,95 1040,72 C1060,58 1072,48 1080,42 C1088,36 1100,42 1120,60 C1145,85 1175,130 1200,155" fill="none" stroke="rgba(0,0,0,0.28)" stroke-width="2" />
          </svg>

          {% for block in section.blocks limit: 5 %}
            {% assign text_parts = block.settings.text | split: "/" %}
            {% assign date_short = "" %}
            {% if text_parts.size > 1 %}
              {% assign date_short = text_parts[1] | strip | truncatewords: 2, "" %}
            {% endif %}
            <div class="elevation-profile__marker"
                 data-round="{{ block.settings.popup_round }}"
                 data-city="{{ block.settings.popup_city }}"
                 data-date="{{ date_short }}"
                 data-elevation="{{ block.settings.popup_elevation }}"
                 data-desc="{{ block.settings.popup_desc }}"
                 data-link="{{ block.settings.popup_link }}">
              <span class="elevation-profile__marker-inner"></span>
            </div>
          {% endfor %}
        </div>
        <div class="elevation-profile__labels">
          {% for block in section.blocks limit: 5 %}
            <div class="elevation-profile__label">
              <span class="elevation-profile__code">{{ block.settings.number }}</span>
              {% assign text_parts = block.settings.text | split: "/" %}
              {% if text_parts.size > 1 %}
                <span class="elevation-profile__date">{{ text_parts[1] | strip | truncatewords: 2, "" }}</span>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<!-- Elevation Tooltip (fixed position, outside overflow) -->
<div class="elevation-tooltip" id="elevationTooltip">
  <span class="elevation-tooltip__round" id="etRound"></span>
  <h4 class="elevation-tooltip__title" id="etTitle"></h4>
  <div class="elevation-tooltip__meta" id="etMeta"></div>
  <p class="elevation-tooltip__desc" id="etDesc"></p>
  <a class="elevation-tooltip__link" id="etLink" href="#">Ver sede &rarr;</a>
  <div class="elevation-tooltip__arrow"></div>
</div>

<script>
(function() {
  var tops = [12.5, 13, 31, 16, 21];

  function alignElevation() {
    var chart = document.querySelector('.elevation-profile__chart');
    if (!chart) return;
    var cards = document.querySelectorAll('.horizontal-stats__card');
    var markers = chart.querySelectorAll('.elevation-profile__marker');
    var labels = document.querySelectorAll('.elevation-profile__label');
    if (cards.length < 5 || markers.length < 5) return;
    var chartRect = chart.getBoundingClientRect();
    for (var i = 0; i < 5; i++) {
      var r = cards[i].getBoundingClientRect();
      var pct = ((r.left + r.width / 2 - chartRect.left) / chartRect.width) * 100;
      markers[i].style.left = pct + '%';
      markers[i].style.top = tops[i] + '%';
      if (labels[i]) labels[i].style.left = pct + '%';
    }
  }

  function initTooltip() {
    var tip = document.getElementById('elevationTooltip');
    var markers = document.querySelectorAll('.elevation-profile__marker');
    if (!tip || !markers.length) return;

    var hideTimer = null;

    function showTip() {
      clearTimeout(hideTimer);
      tip.classList.add('is-visible');
    }

    function schedulHide() {
      hideTimer = setTimeout(function() {
        tip.classList.remove('is-visible');
      }, 350);
    }

    markers.forEach(function(m) {
      m.addEventListener('mouseenter', function() {
        clearTimeout(hideTimer);
        var city = this.dataset.city;
        var round = this.dataset.round;
        if (!city && !round) return;

        document.getElementById('etRound').textContent = round || '';
        document.getElementById('etTitle').textContent = city || '';

        var meta = '';
        if (this.dataset.date) meta += '<span>' + this.dataset.date + '</span>';
        if (this.dataset.elevation) meta += '<span>' + this.dataset.elevation + '</span>';
        document.getElementById('etMeta').innerHTML = meta;

        var descEl = document.getElementById('etDesc');
        descEl.textContent = this.dataset.desc || '';
        descEl.style.display = this.dataset.desc ? 'block' : 'none';

        var linkEl = document.getElementById('etLink');
        if (this.dataset.link) {
          linkEl.href = this.dataset.link;
          linkEl.style.display = 'inline-block';
        } else {
          linkEl.style.display = 'none';
        }

        var rect = this.getBoundingClientRect();
        tip.style.left = (rect.left + rect.width / 2) + 'px';
        tip.style.top = (rect.top - 14) + 'px';
        showTip();
      });

      m.addEventListener('mouseleave', schedulHide);
    });

    tip.addEventListener('mouseenter', showTip);
    tip.addEventListener('mouseleave', schedulHide);
  }

  function init() {
    alignElevation();
    initTooltip();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() { setTimeout(init, 100); });
  } else {
    setTimeout(init, 100);
  }
  window.addEventListener('resize', alignElevation);
})();
</script>

{% schema %}
{
  "name": "Stats Horizontales",
  "settings": [],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Numero / dato",
          "default": "01"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Descripcion",
          "default": "Sede Guanajuato"
        },
        {
          "type": "text",
          "id": "popup_round",
          "label": "Ronda (popup)",
          "info": "Ej: R1, R2..."
        },
        {
          "type": "text",
          "id": "popup_city",
          "label": "Ciudad (popup)",
          "info": "Ej: Guanajuato, GTO"
        },
        {
          "type": "text",
          "id": "popup_elevation",
          "label": "Elevacion (popup)",
          "info": "Ej: 2,100 msnm"
        },
        {
          "type": "textarea",
          "id": "popup_desc",
          "label": "Descripcion (popup)"
        },
        {
          "type": "url",
          "id": "popup_link",
          "label": "Link (popup)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Horizontales",
      "blocks": [
        { "type": "stat", "settings": { "number": "GTO", "text": "Sede 1 — Guanajuato / 21-22 Feb", "popup_round": "R1", "popup_city": "Guanajuato, GTO", "popup_elevation": "2,100 msnm", "popup_desc": "Sede inaugural de la temporada" } },
        { "type": "stat", "settings": { "number": "PUE", "text": "Sede 2 — Puebla / 21-22 Mar", "popup_round": "R2", "popup_city": "Puebla, PUE", "popup_elevation": "2,160 msnm" } },
        { "type": "stat", "settings": { "number": "GDL", "text": "Sede 3 — Guadalajara / 30-31 May", "popup_round": "R3", "popup_city": "Guadalajara, JAL" } },
        { "type": "stat", "settings": { "number": "IXT", "text": "Sede 4 — Ixtapan de la Sal / 18-19 Jul", "popup_round": "R4", "popup_city": "Ixtapan de la Sal, MEX" } },
        { "type": "stat", "settings": { "number": "TAX", "text": "Sede 5 — Taxco / 17-18 Oct — Final Nacional", "popup_round": "R5", "popup_city": "Taxco, GRO", "popup_desc": "Final Nacional" } },
        { "type": "stat", "settings": { "number": "$530K", "text": "Total en premios para la temporada 2026" } }
      ]
    }
  ]
}
{% endschema %}
