<section id="about" class="about">
  <div class="container">
    <span class="label reveal" style="margin-bottom: var(--space-sm);">{{ section.settings.label | default: 'La copa' }}</span>
    <div class="about__grid">
      <div>
        <h2 class="heading-lg about__heading reveal reveal--delay-1">
          {{ section.settings.heading | default: 'La copa nacional de downhill mas grande de Mexico' }}
        </h2>
      </div>
      <div>
        <p class="body-text body-text--lg about__text reveal reveal--delay-2">
          {{ section.settings.description | default: 'Copa Scott DHMEXRACES reune a los mejores pilotos del pais en 5 sedes a lo largo de la temporada. Desde principiantes hasta elite, 13 categorias compiten por el titulo nacional en las pistas mas exigentes del downhill mexicano. Velocidad, tecnica y adrenalina en estado puro.' }}
        </p>
        {% if section.settings.logo != blank %}
          <div class="about__logo reveal reveal--delay-3" style="margin-top: var(--space-lg);">
            <img src="{{ section.settings.logo | image_url: width: 600 }}" alt="{{ section.settings.logo_alt | default: 'Logo' }}" loading="lazy" style="max-width: {{ section.settings.logo_width | default: 300 }}px; width: 100%; height: auto;">
          </div>
        {% endif %}
      </div>
    </div>

    <!-- Stats -->
    <div class="stats reveal reveal--delay-3" style="margin-top: var(--space-xl);">
      {% for block in section.blocks %}
        <div class="stat">
          <div class="stat__number" data-countup="{{ block.settings.number }}" data-suffix="{{ block.settings.suffix | default: '' }}" data-prefix="{{ block.settings.prefix | default: '' }}">
            0
          </div>
          <div class="stat__label">{{ block.settings.label }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sobre la Copa",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "La copa"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "La copa nacional de downhill mas grande de Mexico"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Copa Scott DHMEXRACES reune a los mejores pilotos del pais en 5 sedes a lo largo de la temporada. Desde principiantes hasta elite, 13 categorias compiten por el titulo nacional en las pistas mas exigentes del downhill mexicano. Velocidad, tecnica y adrenalina en estado puro."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Alt del logo",
      "default": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo (px)",
      "min": 100,
      "max": 600,
      "step": 20,
      "default": 300
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadistica",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Numero",
          "default": "5"
        },
        {
          "type": "text",
          "id": "prefix",
          "label": "Prefijo (ej: +)"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Sufijo (ej: K, M, +)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Sedes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sobre la Copa",
      "blocks": [
        { "type": "stat", "settings": { "number": "5", "label": "Sedes nacionales" } },
        { "type": "stat", "settings": { "number": "13", "prefix": "+", "label": "Categorias" } },
        { "type": "stat", "settings": { "number": "530", "prefix": "$", "suffix": "K", "label": "En premios MXN" } },
        { "type": "stat", "settings": { "number": "500", "prefix": "+", "label": "Pilotos por temporada" } }
      ]
    }
  ]
}
{% endschema %}
