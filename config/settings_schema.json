[
  {
    "name": "theme_info",
    "theme_name": "DHMEX SKELETON",
    "theme_version": "1.0.0",
    "theme_author": "PRAZIS DEV",
    "theme_documentation_url": "https://dhmexraces.com",
    "theme_support_url": "https://dhmexraces.com"
  },
  {
    "name": "Tipografia",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "Fuente principal"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Ancho de pagina",
        "options": [
          { "value": "90rem", "label": "Estrecho (90rem)" },
          { "value": "110rem", "label": "Ancho (110rem)" }
        ],
        "default": "110rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Margen de pagina",
        "default": 20
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "Radio de esquinas (inputs)",
        "default": 6
      }
    ]
  },
  {
    "name": "Colores",
    "settings": [
      {
        "type": "color",
        "id": "color_bg_primary",
        "label": "Fondo principal",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_bg_secondary",
        "label": "Fondo secundario",
        "default": "#F5F5F5"
      },
      {
        "type": "color",
        "id": "color_text_primary",
        "label": "Texto principal",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Texto secundario",
        "default": "#666666"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Color acento",
        "default": "#1A1A1A"
      }
    ]
  },
  {
    "name": "Campeonato",
    "settings": [
      {
        "type": "text",
        "id": "event_name",
        "label": "Nombre del campeonato",
        "default": "COPA SCOTT DHMEXRACES"
      },
      {
        "type": "text",
        "id": "event_date",
        "label": "Fecha proxima sede (YYYY-MM-DD)",
        "default": "2026-03-21"
      },
      {
        "type": "text",
        "id": "event_location",
        "label": "Proxima sede",
        "default": "Puebla, Mexico"
      },
      {
        "type": "text",
        "id": "event_season",
        "label": "Temporada",
        "default": "2026"
      }
    ]
  },
  {
    "name": "Redes sociales",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL",
        "default": "https://www.instagram.com/dhmex_races/"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      }
    ]
  }
]
