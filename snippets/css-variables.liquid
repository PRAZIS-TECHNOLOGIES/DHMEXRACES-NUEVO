{% style %}
  :root {
    /* Colors from theme settings */
    --bg-primary: {{ settings.color_bg_primary }};
    --bg-secondary: {{ settings.color_bg_secondary }};
    --text-primary: {{ settings.color_text_primary }};
    --text-secondary: {{ settings.color_text_secondary }};
    --accent: {{ settings.color_accent }};
    --accent-hover: #333333;

    /* DHMEXRACES Brand Colors */
    --color-primary: #1A1A1A;
    --color-secondary: #666666;
    --color-gold: #FFD700;
    --color-success: #10B981;
    --color-error: #EF4444;
    --color-border: rgba(0, 0, 0, 0.1);
    --color-border-accent: rgba(0, 0, 0, 0.15);
  }
{% endstyle %}
