{% comment %}
  Cart Page - DHMEX PRO
  Custom cart with inscription detection, promo jersey sync,
  discount codes, and registration form redirect
  CART PROTECTION SYSTEM - ported from original DHMEXRACES
{% endcomment %}

<div class="cart-page">
  <div class="container">
    <div class="section__header">
      <div class="section__header-left">
        <span class="label">Tu carrito</span>
        <h1 class="heading-lg">Carrito</h1>
      </div>
    </div>

    {% if cart.item_count > 0 %}
      <div class="cart-layout" id="cartContent">
        <div class="cart-items" id="cartItems">
          {% comment %} Render non-promo items first, then promo jerseys {% endcomment %}
          {% for item in cart.items %}
            {% if item.properties['_promo_jersey'] == 'true' %}{% continue %}{% endif %}
            {% assign title_lower = item.product.title | downcase %}
            {% assign is_inscription = false %}
            {% assign is_promo_jersey = false %}

            {% if title_lower contains 'inscripci' %}
              {% assign is_inscription = true %}
            {% endif %}

            <div class="cart-item {% if is_promo_jersey %}cart-item--promo{% endif %}" data-line="{{ forloop.index }}" data-variant-id="{{ item.variant_id }}">
              <a href="{{ item.url }}">
                {% if item.image %}
                  <img class="cart-item__image" src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" loading="lazy">
                {% else %}
                  <div class="cart-item__image" style="background: var(--bg-secondary);"></div>
                {% endif %}
              </a>

              <div class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {% if is_promo_jersey %}
                  <div class="cart-item__variant">Talla: Por definir en formulario</div>
                  <span class="cart-item__promo-badge">JERSEY GRATIS</span>
                  <span class="label" style="margin-top: 4px; opacity: 0.6;">Sincronizado con inscripciones</span>
                {% else %}
                  {% unless item.variant.title == 'Default Title' %}
                    <div class="cart-item__variant">Categoría: {{ item.variant.title }}</div>
                  {% endunless %}
                {% endif %}

                {% for property in item.properties %}
                  {% assign prop_first_char = property.first | slice: 0, 1 %}
                  {% if property.last != blank and prop_first_char != '_' %}
                    <div class="label" style="margin-top: 4px;">{{ property.first }}: {{ property.last }}</div>
                  {% endif %}
                {% endfor %}
              </div>

              <div class="cart-item__qty">
                {% unless is_promo_jersey %}
                  <div class="quantity-selector" style="display: inline-flex;">
                    <button type="button" onclick="updateQuantity({{ forloop.index }}, -1)" aria-label="Menos">&minus;</button>
                    <input type="number" value="{{ item.quantity }}" min="0" readonly aria-label="Cantidad">
                    <button type="button" onclick="updateQuantity({{ forloop.index }}, 1)" aria-label="Mas">+</button>
                  </div>
                  <button type="button" class="cart-item__remove" onclick="removeItem({{ forloop.index }})" aria-label="Eliminar">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                {% endunless %}
              </div>

              <div class="cart-item__price">
                {% if is_promo_jersey %}
                  <span class="cart-item__price-original">{{ item.original_line_price | money }}</span>
                  <span class="cart-item__price-free">GRATIS</span>
                {% else %}
                  {{ item.line_price | money }}
                  {% if item.quantity > 1 %}
                    <span class="cart-item__price-unit">{{ item.price | money }} c/u</span>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          {% endfor %}

          {% comment %} Promo jerseys rendered last {% endcomment %}
          {% for item in cart.items %}
            {% unless item.properties['_promo_jersey'] == 'true' %}{% continue %}{% endunless %}
            {% assign is_promo_jersey = true %}
            {% assign is_inscription = false %}

            <div class="cart-item cart-item--promo" data-line="{{ forloop.index }}" data-variant-id="{{ item.variant_id }}">
              <a href="{{ item.url }}">
                {% if item.image %}
                  <img class="cart-item__image" src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" loading="lazy">
                {% else %}
                  <div class="cart-item__image" style="background: var(--bg-secondary);"></div>
                {% endif %}
              </a>

              <div class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                <div class="cart-item__variant">Talla: Por definir en formulario</div>
                <span class="cart-item__promo-badge">JERSEY GRATIS</span>
                <span class="label" style="margin-top: 4px; opacity: 0.6;">Sincronizado con inscripciones</span>
              </div>

              <div class="cart-item__qty"></div>

              <div class="cart-item__price">
                <span class="cart-item__price-original">{{ item.original_line_price | money }}</span>
                <span class="cart-item__price-free">GRATIS</span>
              </div>
            </div>
          {% endfor %}

          {% assign has_inscriptions_early = false %}
          {% for item in cart.items %}
            {% assign t_check = item.product.title | downcase %}
            {% if t_check contains 'inscripci' %}{% assign has_inscriptions_early = true %}{% endif %}
          {% endfor %}
          {% if has_inscriptions_early %}
          <div class="cart-timeline">
            <div class="cart-timeline__step cart-timeline__step--done">
              <div class="cart-timeline__dot">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span class="cart-timeline__label">Inscripciones agregadas</span>
            </div>
            <div class="cart-timeline__line cart-timeline__line--done"></div>
            <div class="cart-timeline__step cart-timeline__step--active">
              <div class="cart-timeline__dot">2</div>
              <span class="cart-timeline__label">Revisar carrito y continuar</span>
              <span class="cart-timeline__badge">Estas aqui</span>
            </div>
            <div class="cart-timeline__line"></div>
            <div class="cart-timeline__step">
              <div class="cart-timeline__dot">3</div>
              <span class="cart-timeline__label">Datos y tallas de jersey</span>
            </div>
            <div class="cart-timeline__line"></div>
            <div class="cart-timeline__step">
              <div class="cart-timeline__dot">4</div>
              <span class="cart-timeline__label">Pagar</span>
            </div>
          </div>
          {% endif %}
        </div>

        <div class="cart-summary">
          <div class="cart-summary__section">
            <span class="heading-sm">Resumen</span>
          </div>

          {% assign has_inscriptions = false %}
          {% assign inscription_count = 0 %}
          {% assign promo_jersey_total = 0 %}

          {% for item in cart.items %}
            {% assign t = item.product.title | downcase %}
            {% if t contains 'inscripci' %}
              {% assign has_inscriptions = true %}
              {% assign inscription_count = inscription_count | plus: item.quantity %}
            {% endif %}
            {% if item.properties['_promo_jersey'] == 'true' %}
              {% assign promo_jersey_total = promo_jersey_total | plus: item.original_line_price %}
            {% endif %}
          {% endfor %}

          {% if has_inscriptions %}
            <div class="cart-summary__row">
              <span class="label">Inscripciones</span>
              <span class="label">{{ inscription_count }}</span>
            </div>
          {% endif %}

          {% if promo_jersey_total > 0 %}
            <div class="cart-summary__row">
              <span class="label">Jersey Oficial Gratis</span>
              <span class="label" style="color: #DF3382;">-{{ promo_jersey_total | money }}</span>
            </div>
          {% endif %}

          <div class="cart-summary__row cart-summary__row--total">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="cart-summary__row" style="font-size: 11px; color: var(--text-secondary);">
            <span>Impuestos incluidos</span>
          </div>

          <div class="cart-summary__discount" id="discountSection">
            <div id="discountInput" class="cart-discount">
              <input type="text" id="discountCode" placeholder="Codigo de descuento" class="cart-discount__input" autocomplete="off">
              <button type="button" onclick="applyDiscount()" class="btn btn--outline cart-discount__btn">Aplicar</button>
            </div>
            <div id="discountConfirmed" class="cart-discount__confirmed" style="display: none;">
              <span class="label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#DF3382" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Codigo: <strong id="discountCodeDisplay"></strong>
              </span>
              <button type="button" onclick="changeDiscount()" class="label" style="text-decoration: underline; cursor: pointer;">Cambiar</button>
            </div>
          </div>

          {% if has_inscriptions %}
            <button type="button" class="btn btn--primary btn--large" style="width: 100%; margin-top: var(--space-sm); background: #DF3382; box-shadow: 0 0 20px rgba(223, 51, 130, 0.4); display: flex; flex-direction: column; align-items: center; gap: 2px; padding-top: 12px; padding-bottom: 12px;" onclick="proceedToRegistration()">
              <span>Continuar al Registro</span>
              <span style="font-size: 10px; font-weight: 400; opacity: 0.75; letter-spacing: 0.03em;">Siguiente: datos de los corredores (2 min)</span>
            </button>
          {% else %}
            <a href="/checkout" class="btn btn--primary btn--large" style="width: 100%; margin-top: var(--space-sm); text-align: center;">
              Proceder al pago
            </a>
          {% endif %}

          <div style="display: flex; flex-direction: column; align-items: center; gap: 8px; margin-top: var(--space-sm);">
            <div style="display: flex; align-items: center; gap: 6px; opacity: 0.45;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              <span class="label">Pago seguro · 3D Secure</span>
            </div>
            <div style="display: flex; align-items: center; gap: 12px; opacity: 0.35;">
              {%- comment -%} Visa {%- endcomment -%}
              <svg width="40" height="13" viewBox="0 0 750 471" fill="currentColor">
                <path d="M278.2 334.2l33.4-195.3h53.4L331.6 334.2h-53.4zM524.9 142.6c-10.6-4-27.2-8.3-47.9-8.3-52.8 0-90 26.5-90.2 64.5-.3 28.1 26.5 43.7 46.8 53.1 20.8 9.6 27.8 15.7 27.7 24.3-.1 13.1-16.6 19.1-32 19.1-21.4 0-32.7-3-50.3-10.2l-6.9-3.1-7.5 43.8c12.5 5.4 35.6 10.2 59.6 10.4 56.2 0 92.6-26.2 93-66.7.2-22.2-14-39.1-44.8-53.1-18.7-9-30.1-15-30-24.2 0-8.1 9.7-16.8 30.6-16.8 17.4-.3 30.1 3.5 39.9 7.4l4.8 2.2 7.2-42.1zM661.6 138.9h-41.3c-12.8 0-22.4 3.5-28 16.2l-79.4 179.1h56.2s9.2-24.1 11.3-29.4c6.1 0 60.8.1 68.6.1 1.6 6.9 6.5 29.3 6.5 29.3h49.7l-43.6-195.3zm-65.9 126c4.4-11.3 21.4-54.7 21.4-54.7-.3.5 4.4-11.3 7.1-18.7l3.6 16.9s10.3 46.8 12.4 56.6h-44.5zM232.8 138.9L180.5 271l-5.6-27.1c-9.7-31.2-39.9-65-73.7-81.9l47.9 171.1 56.6-.1 84.2-195.2h-56.6z"/>
                <path d="M131.9 138.9H44.7l-.7 4c67.2 16.2 111.7 55.3 130.1 102.3L156 159.4c-3-12.4-12.6-16-24.1-16.5z"/>
              </svg>
              {%- comment -%} Mastercard {%- endcomment -%}
              <svg width="32" height="20" viewBox="0 0 152 100" fill="currentColor">
                <circle cx="50" cy="50" r="50" opacity="0.6"/>
                <circle cx="102" cy="50" r="50" opacity="0.6"/>
              </svg>
              {%- comment -%} Amex {%- endcomment -%}
              <svg width="32" height="20" viewBox="0 0 120 80" fill="none" stroke="currentColor" stroke-width="4">
                <rect x="2" y="2" width="116" height="76" rx="8"/>
                <text x="60" y="52" text-anchor="middle" font-family="monospace" font-size="28" font-weight="bold" fill="currentColor" stroke="none">AMEX</text>
              </svg>
            </div>
          </div>

          <a href="/#sedes" class="label" style="display: block; text-align: center; margin-top: var(--space-sm); text-decoration: underline; opacity: 0.5;">
            Seguir comprando
          </a>
        </div>
      </div>

    {% else %}
      <div style="text-align: center; padding: var(--space-xl) 0;">
        <p class="heading-md" style="margin-bottom: var(--space-md);">{{ section.settings.empty_title | default: 'Tu carrito esta vacio' }}</p>
        <a href="/products/inscripcion-sede-2-guadalajara" class="btn btn--primary">Inscribirme ahora</a>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .cart-page {
    padding: calc(var(--header-height) + var(--space-lg)) 0 var(--space-lg);
    min-height: 60vh;
  }
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-lg);
    align-items: start;
  }
  @media (max-width: 968px) {
    .cart-layout {
      grid-template-columns: 1fr;
    }
  }
  .cart-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto auto;
    gap: var(--space-sm);
    align-items: center;
    padding: var(--space-sm);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    background: var(--bg-secondary);
  }
  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-self: center;
  }
  .cart-item--promo {
    border-color: rgba(223, 51, 130, 0.3);
    background: rgba(223, 51, 130, 0.05);
  }
  .cart-item__image {
    width: 80px;
    height: auto;
    min-height: 80px;
    object-fit: contain;
    border-radius: 6px;
  }
  .cart-item__details {
    display: flex;
    flex-direction: column;
  }
  .cart-item__title {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
  }
  .cart-item__title:hover {
    color: var(--accent);
  }
  .cart-item__promo-badge {
    display: inline-block;
    margin-top: 6px;
    padding: 2px 8px;
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #000;
    border: 1px solid #000;
    border-radius: 4px;
    width: fit-content;
  }
  .cart-item__variant {
    margin-top: 4px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #DF3382;
  }
  .cart-item__remove {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: 4px;
  }
  .cart-item__remove:hover {
    color: var(--accent);
  }
  .cart-item__price {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    text-align: right;
    white-space: nowrap;
  }
  .cart-item__price-original {
    text-decoration: line-through;
    color: var(--text-secondary);
    font-size: 12px;
    display: block;
  }
  .cart-item__price-free {
    color: #DF3382;
    font-weight: 700;
  }
  .cart-item__price-unit {
    display: block;
    font-size: 11px;
    font-weight: 400;
    color: var(--text-secondary);
  }
  .cart-summary {
    padding: var(--space-md);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    background: var(--bg-secondary);
    position: sticky;
    top: calc(72px + var(--space-md));
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cart-summary__row--total {
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(0,0,0,0.08);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
  }
  .cart-discount {
    display: flex;
    gap: 8px;
  }
  .cart-discount__input {
    flex: 1;
    padding: 8px 12px;
    background: var(--bg-primary);
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 6px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 13px;
  }
  .cart-discount__input::placeholder {
    color: var(--text-secondary);
  }

  /* ── Cart Timeline ── */
  .cart-discount__btn {
    padding: 8px 16px !important;
    font-size: 11px !important;
    white-space: nowrap;
  }
  .cart-discount__confirmed {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: rgba(223, 51, 130, 0.08);
    border-radius: 6px;
  }

  /* ── Skeleton Loading ── */
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.08; }
  }
  .cart-skeleton {
    position: absolute;
    top: -2px;
    left: -10px;
    right: -10px;
    bottom: -2px;
    z-index: 3;
    pointer-events: all;
    background: var(--bg-primary, #fff);
    overflow: hidden;
    padding: 0 10px;
  }
  .cart-skeleton .cart-items,
  .cart-skeleton .cart-summary {
    pointer-events: none;
  }
  .cart-skeleton .skel-block {
    background: var(--text-primary);
    border-radius: 4px;
    animation: skeleton-pulse 1.2s ease-in-out infinite;
  }
  .cart-skeleton .skel-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: var(--space-sm);
    align-items: center;
    padding: var(--space-sm);
    border: none;
    border-radius: 8px;
    background: var(--bg-secondary);
  }
  .cart-skeleton .skel-img {
    width: 80px;
    height: 80px;
    border-radius: 6px;
  }
  .cart-skeleton .skel-lines {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cart-skeleton .skel-line {
    height: 12px;
    border-radius: 3px;
  }
  .cart-skeleton .skel-line--title { width: 70%; }
  .cart-skeleton .skel-line--cat { width: 40%; }
  .cart-skeleton .skel-line--price { width: 60px; height: 14px; }
  .cart-skeleton .skel-summary-line {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  .cart-skeleton .skel-btn {
    height: 44px;
    border-radius: 8px;
    width: 100%;
  }

  /* ── Mobile Cart ── */
  @media (max-width: 600px) {
    .cart-page {
      padding: calc(var(--header-height) + var(--space-sm)) 0 var(--space-md);
    }
    .cart-page .container {
      padding-left: 12px;
      padding-right: 12px;
    }
    .cart-page .section__header {
      margin-bottom: var(--space-sm);
    }
    .cart-page .heading-lg {
      font-size: clamp(1.5rem, 6vw, 2.4rem);
    }
    .cart-layout {
      gap: var(--space-md);
    }
    .cart-item {
      grid-template-columns: 56px 1fr;
      grid-template-rows: auto auto;
      gap: 8px;
      padding: 10px;
      position: relative;
    }
    .cart-item__image {
      width: 56px;
      min-height: 56px;
      grid-row: 1 / 2;
    }
    .cart-item__details {
      grid-column: 2;
      grid-row: 1;
      min-width: 0;
    }
    .cart-item__title {
      font-size: 12px;
      word-break: break-word;
    }
    .cart-item__variant {
      font-size: 11px !important;
    }
    .cart-item__promo-badge {
      font-size: 9px !important;
      padding: 2px 6px !important;
    }
    .cart-item__qty {
      grid-column: 1 / -1;
      grid-row: 2;
      justify-self: start;
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
    }
    .cart-item__qty .quantity-selector {
      transform: scale(0.85);
      transform-origin: left center;
    }
    .cart-item__remove {
      position: absolute;
      top: 6px;
      right: 6px;
      z-index: 2;
      padding: 6px;
    }
    .cart-item__price {
      grid-column: 1 / -1;
      grid-row: 2;
      text-align: right;
      font-size: 12px;
      align-self: center;
    }
    .cart-item__price-original {
      font-size: 11px !important;
    }
    .cart-summary {
      position: static;
      padding: var(--space-sm);
      gap: 8px;
    }
    .cart-summary__row--total {
      font-size: 16px;
    }
    .cart-discount {
      flex-direction: column;
      gap: 6px;
    }
    .cart-discount__input {
      font-size: 14px;
      padding: 10px 12px;
    }
    .cart-discount__btn {
      padding: 10px 16px !important;
      font-size: 12px !important;
    }
    .cart-timeline {
      padding: 10px 6px;
    }
    .cart-timeline__step {
      min-width: 50px;
    }
    .cart-timeline__label {
      font-size: 8px;
      max-width: 55px;
    }
    .cart-timeline__dot {
      width: 22px;
      height: 22px;
      font-size: 9px;
    }
    .cart-timeline__dot svg {
      width: 11px;
      height: 11px;
    }
    .cart-timeline__badge {
      font-size: 7px;
      padding: 1px 4px;
    }
    .cart-timeline__line {
      min-width: 10px;
      margin-top: 11px;
    }
    .cart-skeleton .skel-item {
      grid-template-columns: 56px 1fr;
      padding: 10px;
    }
    .cart-skeleton .skel-img {
      width: 56px;
      height: 56px;
    }
    .cart-skeleton .cart-summary {
      border: none;
    }
  }
</style>

<script>
// ============================================================
// CART PROTECTION SYSTEM - DHMEX SKELETON
// Full error handling ported from original DHMEXRACES cart
// ============================================================

var isProcessing = false;

// ============ UI STATE MANAGEMENT ============
function setProcessingState(processing) {
  isProcessing = processing;
  var content = document.getElementById('cartContent');
  if (content) content.style.opacity = processing ? '0.5' : '1';

  // Disable/enable all cart buttons
  var buttons = document.querySelectorAll('.quantity-selector button, .cart-item__remove, .btn--primary, .btn--outline');
  for (var i = 0; i < buttons.length; i++) {
    buttons[i].disabled = processing;
    buttons[i].style.opacity = processing ? '0.5' : '';
    buttons[i].style.cursor = processing ? 'wait' : '';
  }

  // Skeleton screen overlay
  var loader = document.getElementById('cartSkeleton');
  if (processing) {
    if (!loader) {
      var layout = document.querySelector('.cart-layout');
      if (layout) {
        loader = document.createElement('div');
        loader.id = 'cartSkeleton';
        loader.className = 'cart-skeleton';

        var itemCount = document.querySelectorAll('.cart-item').length || 2;
        var itemsHtml = '';
        for (var j = 0; j < itemCount; j++) {
          itemsHtml += '<div class="skel-item">'
            + '<div class="skel-block skel-img"></div>'
            + '<div class="skel-lines">'
            + '<div class="skel-block skel-line skel-line--title"></div>'
            + '<div class="skel-block skel-line skel-line--cat"></div>'
            + '</div>'
            + '<div class="skel-block skel-line skel-line--price"></div>'
            + '</div>';
        }

        loader.innerHTML = '<div class="cart-layout">'
          + '<div class="cart-items">' + itemsHtml + '</div>'
          + '<div class="cart-summary" style="border:none;">'
          + '<div class="skel-summary-line"><div class="skel-block skel-line" style="width:80px"></div><div class="skel-block skel-line" style="width:40px"></div></div>'
          + '<div class="skel-summary-line"><div class="skel-block skel-line" style="width:60px"></div><div class="skel-block skel-line" style="width:50px"></div></div>'
          + '<div class="skel-summary-line" style="margin-top:8px;padding-top:8px;border-top:1px solid rgba(0,0,0,0.06)"><div class="skel-block skel-line" style="width:50px;height:16px"></div><div class="skel-block skel-line" style="width:70px;height:16px"></div></div>'
          + '<div class="skel-block skel-btn" style="margin-top:12px"></div>'
          + '</div>'
          + '</div>';

        layout.style.position = 'relative';
        layout.appendChild(loader);
      }
    }
  } else if (loader) {
    loader.remove();
  }
}

// ============ ITEM TYPE DETECTION ============
function isInscriptionItem(item) {
  var t = (item.product_title || item.title || '').toLowerCase();
  return t.includes('inscripcion') || t.includes('inscripción') || t.includes('inscripci');
}

function isPromoJersey(item) {
  return (item.properties || {})['_promo_jersey'] === 'true';
}

// ============ CART OPERATIONS ============
async function updateCart(line, quantity) {
  if (isProcessing) return;
  setProcessingState(true);

  try {
    // Step 1: Get current cart and validate
    var cartRes = await fetch('/cart.js');
    if (!cartRes.ok) throw new Error('No se pudo obtener el carrito');
    var cart = await cartRes.json();

    // Validate line number
    if (line < 1 || line > cart.items.length) {
      throw new Error('Línea de carrito inválida');
    }

    var itemBeingChanged = cart.items[line - 1];
    var isInscription = isInscriptionItem(itemBeingChanged);

    // Step 2: Perform the update
    var updateRes = await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: quantity })
    });

    if (!updateRes.ok) {
      var errData = await updateRes.json().catch(function() { return {}; });
      throw new Error(errData.description || 'Error al actualizar cantidad');
    }

    // Step 3: If inscription changed, sync promo jerseys
    if (isInscription) {
      await syncPromoJerseysWithInscriptions();
    }

    // Step 4: Reload
    window.location.reload();

  } catch (error) {
    console.error('Error updating cart:', error);
    setProcessingState(false);
    alert('Error al actualizar el carrito: ' + error.message + '\n\nPor favor recarga la página e intenta de nuevo.');
  }
}

function updateQuantity(line, change) {
  if (isProcessing) return;

  fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
    var item = cart.items[line - 1];
    if (!item) return;
    var newQty = Math.max(0, Math.min(10, item.quantity + change));
    if (newQty === 0) { removeItem(line); return; }
    if (newQty === item.quantity) return;
    updateCart(line, newQty);
  });
}

function removeItem(line) {
  if (isProcessing) return;
  if (!confirm('¿Eliminar este artículo del carrito?')) return;
  updateCart(line, 0);
}

// ============ PROMO JERSEY SYNC ============
async function syncPromoJerseysWithInscriptions() {
  try {
    var cartResponse = await fetch('/cart.js');
    if (!cartResponse.ok) return;
    var cart = await cartResponse.json();

    var totalInscriptions = cart.items
      .filter(function(item) { return isInscriptionItem(item); })
      .reduce(function(total, item) { return total + item.quantity; }, 0);

    var promoJerseys = cart.items.filter(function(item) { return isPromoJersey(item); });
    var totalPromoJerseys = promoJerseys.reduce(function(total, item) { return total + item.quantity; }, 0);

    // Check inventory
    var inventoryDisponibles = null;
    try {
      var detectedSede = 'guanajuato';
      var inscriptionItems = cart.items.filter(function(item) { return isInscriptionItem(item); });
      for (var i = 0; i < inscriptionItems.length; i++) {
        var title = (inscriptionItems[i].product_title || inscriptionItems[i].title || '').toLowerCase();
        if (title.includes('guadalajara')) { detectedSede = 'guadalajara'; break; }
        else if (title.includes('puebla')) { detectedSede = 'puebla'; break; }
        else if (title.includes('ixtapan')) { detectedSede = 'ixtapan'; break; }
        else if (title.includes('taxco')) { detectedSede = 'taxco'; break; }
        else if (title.includes('guanajuato')) { detectedSede = 'guanajuato'; break; }
      }
      var invResponse = await fetch('https://dhmexraces-webhooks.vercel.app/api/inventory');
      var invData = await invResponse.json();
      inventoryDisponibles = (invData.sedes && invData.sedes[detectedSede] && invData.sedes[detectedSede].playeras) ? invData.sedes[detectedSede].playeras.disponibles : 50;
    } catch (invErr) {
      console.error('Error fetching inventory:', invErr);
    }

    // If jerseys sold out, remove all promos
    if (inventoryDisponibles !== null && inventoryDisponibles <= 0 && totalPromoJerseys > 0) {
      while (promoJerseys.length > 0) {
        var jersey = promoJerseys[0];
        var jerseyLine = cart.items.indexOf(jersey) + 1;
        await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ line: jerseyLine, quantity: 0 })
        });
        await new Promise(function(r) { setTimeout(r, 150); });
        cartResponse = await fetch('/cart.js');
        cart = await cartResponse.json();
        promoJerseys = cart.items.filter(function(item) { return isPromoJersey(item); });
      }
      location.reload();
      return;
    }

    // If already synced, skip
    if (promoJerseys.length === 1 && totalPromoJerseys === totalInscriptions && inventoryDisponibles > 0) {
      return;
    }

    // If no inscriptions, remove all promos
    if (totalInscriptions === 0) {
      while (promoJerseys.length > 0) {
        var jrs = promoJerseys[0];
        var jrsLine = cart.items.indexOf(jrs) + 1;
        await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ line: jrsLine, quantity: 0 })
        });
        await new Promise(function(r) { setTimeout(r, 150); });
        cartResponse = await fetch('/cart.js');
        cart = await cartResponse.json();
        promoJerseys = cart.items.filter(function(item) { return isPromoJersey(item); });
      }
      return;
    }

    // Get variant ID before removing
    var jerseyVariantId = null;
    if (promoJerseys.length > 0) {
      jerseyVariantId = promoJerseys[0].variant_id;
    }

    // Remove all promo jerseys
    while (promoJerseys.length > 0) {
      var pj = promoJerseys[0];
      var pjLine = cart.items.indexOf(pj) + 1;
      await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: pjLine, quantity: 0 })
      });
      await new Promise(function(r) { setTimeout(r, 150); });
      cartResponse = await fetch('/cart.js');
      cart = await cartResponse.json();
      promoJerseys = cart.items.filter(function(item) { return isPromoJersey(item); });
    }

    // Add back with correct quantity (capped by inventory)
    var jerseyQty = totalInscriptions;
    if (inventoryDisponibles !== null) {
      jerseyQty = Math.min(totalInscriptions, inventoryDisponibles);
    }

    if (jerseyVariantId && jerseyQty > 0) {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: jerseyVariantId,
          quantity: jerseyQty,
          properties: { '_promo_jersey': 'true' }
        })
      });
    }

  } catch (error) {
    console.error('Error syncing promo jerseys:', error);
  }
}

// ============ REGISTRATION REDIRECT ============
async function proceedToRegistration() {
  if (isProcessing) return;
  setProcessingState(true);

  try {
    var res = await fetch('/cart.js');
    if (!res.ok) throw new Error('No se pudo obtener el carrito');
    var cart = await res.json();

    var cartItems = cart.items.filter(function(i) {
      var t = (i.product_title || '').toLowerCase();
      return t.includes('inscripci');
    }).map(function(i) {
      return {
        variant_id: String(i.variant_id),
        variant_title: i.variant_title || i.title,
        product_title: i.product_title,
        quantity: i.quantity,
        price: i.price,
        line_price: i.line_price
      };
    });

    if (cartItems.length === 0) {
      throw new Error('No hay inscripciones en el carrito');
    }

    sessionStorage.setItem('registrationCartData', JSON.stringify(cartItems));

    var promoJersey = cart.items.find(function(i) {
      return (i.properties || {})['_promo_jersey'] === 'true';
    });

    if (promoJersey) {
      sessionStorage.setItem('jerseyDisponible', JSON.stringify({
        disponible: true,
        count: promoJersey.quantity,
        sede: ''
      }));
    } else {
      sessionStorage.removeItem('jerseyDisponible');
    }

    // Get discount code from localStorage or input
    var discountCode = localStorage.getItem('discountCode') || '';
    if (!discountCode) {
      var codeDisplay = document.getElementById('discountCodeDisplay');
      var codeInput = document.getElementById('discountCode');
      if (codeDisplay && codeDisplay.textContent.trim()) {
        discountCode = codeDisplay.textContent.trim().toUpperCase();
      } else if (codeInput && codeInput.value.trim()) {
        discountCode = codeInput.value.trim().toUpperCase();
      }
    }

    if (discountCode) {
      sessionStorage.setItem('discountCode', discountCode);
    } else {
      sessionStorage.removeItem('discountCode');
    }

    window.location.href = '/pages/formulario-de-inscripcion';

  } catch (error) {
    console.error('Registration redirect error:', error);
    setProcessingState(false);
    alert('Error al procesar: ' + error.message + '\n\nPor favor intenta de nuevo.');
  }
}

// ============ DISCOUNT CODE ============
function applyDiscount() {
  var input = document.getElementById('discountCode');
  var code = (input.value || '').trim().toUpperCase();
  if (!code) {
    input.style.borderColor = '#DF3382';
    setTimeout(function() { input.style.borderColor = ''; }, 2000);
    return;
  }
  localStorage.setItem('discountCode', code);
  document.getElementById('discountInput').style.display = 'none';
  document.getElementById('discountConfirmed').style.display = 'flex';
  document.getElementById('discountCodeDisplay').textContent = code;
}

function changeDiscount() {
  localStorage.removeItem('discountCode');
  document.getElementById('discountInput').style.display = 'flex';
  document.getElementById('discountConfirmed').style.display = 'none';
  document.getElementById('discountCode').value = '';
}

// ============ PAGE LOAD ============
document.addEventListener('DOMContentLoaded', function() {
  var saved = localStorage.getItem('discountCode');
  if (saved) {
    document.getElementById('discountInput').style.display = 'none';
    document.getElementById('discountConfirmed').style.display = 'flex';
    document.getElementById('discountCodeDisplay').textContent = saved;
  }

  var discountInput = document.getElementById('discountCode');
  if (discountInput) {
    discountInput.addEventListener('input', function() {
      this.value = this.value.toUpperCase();
    });
    discountInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); applyDiscount(); }
    });
  }

  // Sync promo jerseys on page load
  syncPromoJerseysWithInscriptions().catch(function(err) {
    console.error('Error in initial sync:', err);
  });
});
</script>
